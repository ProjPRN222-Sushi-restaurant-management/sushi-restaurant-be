@page "{id:long}"
@model _290526_SushiRestaurantManagement_BE.Pages.Admin.EditMenuItemModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chỉnh Sửa Món Ăn";
}

<style>
    .edit-menu-page {
        padding: 8px 0 32px;
    }

    .edit-menu-wrapper {
        max-width: 720px;
        margin: 0 auto;
    }

    .edit-header {
        margin-bottom: 24px;
    }

    .edit-title {
        color: #991b1b;
        font-weight: 900;
        margin: 0;
    }

    .edit-subtitle {
        color: #64748b;
        font-weight: 500;
        margin-top: 4px;
    }

    .edit-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 26px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(15, 23, 42, .1);
    }

    .edit-card-header {
        padding: 28px 26px;
        color: #ffffff;
        background: linear-gradient(135deg, #dc2626, #f97316);
    }

    .edit-card-title {
        font-weight: 900;
        margin: 0;
    }

    .edit-card-subtitle {
        opacity: .95;
        margin-top: 6px;
        font-weight: 500;
    }

    .edit-card-body {
        padding: 28px;
    }

    .form-label-custom {
        color: #475569;
        font-size: .9rem;
        font-weight: 800;
        margin-bottom: 7px;
    }

    .edit-form .form-control,
    .edit-form .form-select {
        border-radius: 16px;
        border: 1px solid #dbe3ef;
        padding: 12px 14px;
        font-weight: 600;
        color: #1f2937;
    }

        .edit-form .form-control:focus,
        .edit-form .form-select:focus {
            border-color: #f97316;
            box-shadow: 0 0 0 .2rem rgba(249, 115, 22, .15);
        }

    .available-box {
        margin-top: 20px;
        padding: 18px 20px;
        border-radius: 20px;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
    }

    .available-title {
        color: #1f2937;
        font-weight: 900;
    }

    .available-subtitle {
        color: #64748b;
        font-size: .9rem;
        font-weight: 500;
    }

    .form-switch .form-check-input {
        width: 3.1em;
        height: 1.6em;
        cursor: pointer;
    }

        .form-switch .form-check-input:checked {
            background-color: #16a34a;
            border-color: #16a34a;
        }

    .form-switch .form-check-label {
        color: #166534;
        font-weight: 900;
    }

    .action-area {
        display: grid;
        gap: 12px;
        margin-top: 24px;
    }

    .btn-save,
    .btn-back {
        border: none;
        border-radius: 999px;
        padding: 13px 24px;
        font-weight: 900;
        text-align: center;
        text-decoration: none;
        transition: all .2s ease;
    }

    .btn-save {
        color: #ffffff;
        background: linear-gradient(135deg, #dc2626, #f97316);
        box-shadow: 0 14px 28px rgba(220, 38, 38, .25);
    }

        .btn-save:hover {
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 18px 34px rgba(220, 38, 38, .34);
        }

    .btn-back {
        background: #f1f5f9;
        color: #334155;
    }

        .btn-back:hover {
            background: #e2e8f0;
            color: #0f172a;
            transform: translateY(-2px);
        }

    @@media (max-width: 576px) {
        .edit-card-body {
            padding: 22px;
        }
    }
</style>

<div class="edit-menu-page">
    <div class="edit-menu-wrapper">

        <div class="edit-header">
            <h2 class="edit-title">
                Chỉnh Sửa Món Ăn
            </h2>
            <div class="edit-subtitle">
                Cập nhật tên món, danh mục, giá bán và trạng thái món ăn
            </div>
        </div>

        <div class="edit-card">
            <div class="edit-card-header">
                <h5 class="edit-card-title">
                    <i class="fa-solid fa-pen-to-square me-2"></i>
                    Món ăn #@Model.MenuItem.MenuItemId
                </h5>

                <div class="edit-card-subtitle">
                    Thông tin chi tiết món ăn trong thực đơn
                </div>
            </div>

            <div class="edit-card-body">
                <form method="post" class="edit-form">
                    <input type="hidden" asp-for="MenuItem.MenuItemId" />

                    <div class="mb-3">
                        <label class="form-label-custom">Tên món ăn</label>
                        <input asp-for="MenuItem.ItemName"
                               class="form-control"
                               required />
                        <span asp-validation-for="MenuItem.ItemName"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label-custom">Danh mục nhóm món</label>
                        <select asp-for="MenuItem.CategoryId"
                                class="form-select"
                                asp-items="@(new SelectList(Model.Categories, "CategoryId", "CategoryName"))"
                                required>
                        </select>
                        <span asp-validation-for="MenuItem.CategoryId"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label-custom">Đơn giá (VNĐ)</label>
                        <input asp-for="MenuItem.Price"
                               type="number"
                               step="any"
                               class="form-control"
                               min="0"
                               required />
                        <span asp-validation-for="MenuItem.Price"
                              class="text-danger small"></span>
                    </div>

                    <div class="available-box">
                        <div>
                            <div class="available-title">
                                Trạng thái món ăn
                            </div>
                            <div class="available-subtitle">
                                Bật nếu món hiện đang có thể phục vụ
                            </div>
                        </div>

                        <div class="form-check form-switch m-0">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="IsAvailableSwitch"
                                   name="IsAvailableInput"
                                   value="true"
                                   @(Model.MenuItem.IsAvailable == true ? "checked" : "") />

                            <label class="form-check-label ms-2"
                                   for="IsAvailableSwitch">
                                Còn món ăn
                            </label>
                        </div>
                    </div>

                    <div class="action-area">
                        <button type="submit" class="btn-save">
                            Lưu thay đổi
                        </button>

                        <a asp-page="/Admin/MenuManager"
                           class="btn-back">
                            Quay lại danh sách
                        </a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}