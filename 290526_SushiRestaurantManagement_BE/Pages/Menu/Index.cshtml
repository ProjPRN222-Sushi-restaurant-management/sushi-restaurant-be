@page
@model _290526_SushiRestaurantManagement_BE.Pages.Menu.IndexModel

<h2>Menu Sushi</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<div class="menu-grid">
    @foreach (var item in Model.MenuItems)
    {
        <div class="menu-card">
            <img src="@item.ImageUrl" alt="@item.ItemName" style="width:100%;height:180px;object-fit:cover;" />

            <h4>@item.ItemName</h4>
            <p>@item.Description</p>
            <strong>@item.Price.ToString("N0") đ</strong>

            <form method="post" asp-page="/Cart/Index" asp-page-handler="Add" class="menu-add-form">
                <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                <input type="hidden" name="bookingId" value="@Model.BookingId" />
                <input type="hidden" name="tableId" value="@Model.TableId" />
                <input type="hidden" name="scrollY" value="@Model.ScrollY" />

                <label>Số lượng</label>
                <input type="number" name="quantity" value="1" min="1" class="form-control" />

                <label>Tùy chọn</label>
                <textarea name="note" class="form-control"
                      placeholder="Không wasabi, ít cơm, thêm gừng, dị ứng hải sản..."></textarea>

                <button class="btn btn-primary mt-2">Thêm vào giỏ</button>
            </form>
        </div>
    }
</div>
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('form.menu-add-form').forEach(function (form) {
                form.addEventListener('submit', function () {
                    var scrollInput = form.querySelector('input[name="scrollY"]');
                    if (scrollInput) {
                        scrollInput.value = Math.round(window.scrollY || 0);
                    }
                });
            });

            var params = new URLSearchParams(window.location.search);
            var scrollY = parseInt(params.get('scrollY') || '0', 10);
            if (!isNaN(scrollY) && scrollY > 0) {
                window.scrollTo(0, scrollY);
            }
        });
    </script>
}