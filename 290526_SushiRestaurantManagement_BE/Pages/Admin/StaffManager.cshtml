@page
@model _290526_SushiRestaurantManagement_BE.Pages.Admin.StaffManagerModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản Lý Nhân Viên";
    ViewBag.PaginatedList = Model.StaffList;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin-staff-manager.css" asp-append-version="true" />
}


<div class="staff-page">

    @if (TempData["Success"] != null)
    {
        <div class="alert admin-alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>
            @TempData["Success"]
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert admin-alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i>
            @TempData["Error"]
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    }

    <div class="staff-header">
        <div>
            <h2 class="staff-title">
                <i class="fa-solid fa-user-tie me-2"></i>
                Quản Lý Nhân Viên
            </h2>

            <div class="staff-subtitle">
                Quản lý tài khoản, trạng thái và thông tin nhân viên
            </div>
        </div>

        <button type="button"
                class="btn-add-staff"
                data-bs-toggle="modal"
                data-bs-target="#addStaffModal">
            <i class="fa-solid fa-user-plus me-1"></i>
            Thêm Nhân Viên
        </button>
    </div>

    <div class="search-card">
        <form method="get" class="row g-3 align-items-center">
            <div class="col-sm-9">
                <input type="text"
                       name="SearchString"
                       class="form-control search-input"
                       placeholder="Tìm theo tên hoặc số điện thoại..."
                       value="@Model.SearchString" />
            </div>

            <div class="col-sm-3">
                <button type="submit"
                        class="btn-search w-100">
                    Tìm kiếm
                </button>
            </div>
        </form>
    </div>

    <div class="staff-card">
        <div class="staff-card-header">
            <span>Danh Sách Nhân Viên</span>

            <span class="staff-count-badge">
                @Model.StaffList.Items.Count nhân viên
            </span>
        </div>

        <div class="table-responsive">
            <table class="table staff-table">
                <thead>
                    <tr>
                        <th class="ps-3">Mã NV</th>
                        <th>Họ và Tên</th>
                        <th>Số Điện Thoại</th>
                        <th>Trạng Thái</th>
                        <th>Ngày Tạo</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var staff in Model.StaffList.Items)
                    {
                        <tr>
                            <td class="ps-3 staff-id">
                                #@staff.StaffId
                            </td>

                            <td class="staff-name">
                                @staff.FullName
                            </td>

                            <td>
                                <span class="phone-pill">
                                    @staff.Phone
                                </span>
                            </td>

                            <td>
                                @if (staff.IsActive == true)
                                {
                                    <span class="status-pill status-active">
                                        Đang hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="status-pill status-locked">
                                        Bị khóa
                                    </span>
                                }
                            </td>

                            <td>
                                <span class="date-pill">
                                    @(staff.CreatedAt?.ToString("dd/MM/yyyy") ?? "-")
                                </span>
                            </td>

                            <td class="text-center">
                                <div class="action-group">
                                    <a asp-page="/Admin/EditStaff"
                                       asp-route-id="@staff.StaffId"
                                       class="btn-edit">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                        Sửa
                                    </a>

                                    <form method="post"
                                          asp-page-handler="Delete"
                                          asp-route-id="@staff.StaffId"
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa nhân viên này?');"
                                          class="d-inline">
                                        <button type="submit" class="btn-delete">
                                            <i class="fa-solid fa-trash"></i>
                                            Xóa
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }

                    @if (!Model.StaffList.Items.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center empty-row">
                                Không tìm thấy nhân viên nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.StaffList.Items.Any())
    {
        <partial name="_Pagination" />
    }

</div>

<div class="modal fade staff-modal" id="addStaffModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="AddStaff">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fa-solid fa-user-plus me-2"></i>
                        Thêm Nhân Viên Mới
                    </h5>

                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Họ và tên</label>
                        <input type="text"
                               name="NewFullName"
                               class="form-control"
                               required
                               placeholder="Nhập đầy đủ họ tên..." />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Số điện thoại (Dùng đăng nhập)</label>
                        <input type="text"
                               name="NewPhone"
                               class="form-control"
                               required
                               placeholder="Ví dụ: 0912345678" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mật khẩu ban đầu</label>
                        <input type="password"
                               name="NewPassword"
                               class="form-control"
                               required
                               placeholder="Ít nhất 6 ký tự..." />
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn-modal-cancel"
                            data-bs-dismiss="modal">
                        Hủy
                    </button>

                    <button type="submit"
                            class="btn-modal-save">
                        Thêm nhân viên
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>