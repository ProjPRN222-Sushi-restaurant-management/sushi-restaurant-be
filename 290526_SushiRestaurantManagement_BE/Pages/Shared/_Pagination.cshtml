@{
    var paginatedList = ViewBag.PaginatedList as _290526_SushiRestaurantManagement_BE.Helpers.PaginatedList<dynamic>;
}

@if (paginatedList != null && paginatedList.TotalPages > 1)
{
    <nav aria-label="Pagination Navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            @if (paginatedList.HasPreviousPage)
            {
                <li class="page-item">
                    <a class="page-link" href="?PageNumber=1" aria-label="First page">First</a>
                </li>
                <li class="page-item">
                    <a class="page-link" href="?PageNumber=@(paginatedList.PageNumber - 1)" aria-label="Previous page">Previous</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">First</span>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Previous</span>
                </li>
            }

            @for (int i = 1; i <= paginatedList.TotalPages; i++)
            {
                if (i == paginatedList.PageNumber)
                {
                    <li class="page-item active">
                        <span class="page-link">
                            @i <span class="visually-hidden">(current)</span>
                        </span>
                    </li>
                }
                else if (i <= paginatedList.PageNumber + 2 && i >= paginatedList.PageNumber - 2)
                {
                    <li class="page-item">
                        <a class="page-link" href="?PageNumber=@i">@i</a>
                    </li>
                }
            }

            @if (paginatedList.HasNextPage)
            {
                <li class="page-item">
                    <a class="page-link" href="?PageNumber=@(paginatedList.PageNumber + 1)" aria-label="Next page">Next</a>
                </li>
                <li class="page-item">
                    <a class="page-link" href="?PageNumber=@(paginatedList.TotalPages)" aria-label="Last page">Last</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">Next</span>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Last</span>
                </li>
            }
        </ul>
    </nav>
    <div class="text-center text-muted small">
        Page @paginatedList.PageNumber of @paginatedList.TotalPages | Total: @paginatedList.TotalItems items
    </div>
}
