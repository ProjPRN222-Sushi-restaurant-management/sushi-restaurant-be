@page
@model _290526_SushiRestaurantManagement_BE.Pages.Auth.RegisterModel
@{
    ViewData["Title"] = "Đăng ký Nhân viên";
    // Lấy Role từ Session để kiểm tra quyền Admin đăng nhập
    var currentRole = HttpContext.Session.GetString("StaffRole");
}

<div class="container mt-5" style="max-width: 600px;">
    @if (currentRole == "Admin")
    {
        <div class="card border-0 shadow-sm mb-4 bg-dark text-white rounded-3">
            <div class="card-body d-flex justify-content-between align-items-center py-2.5 px-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="fa-solid fa-user-shield text-warning"></i>
                    <span class="small fw-semibold text-light">Chế độ: Quản trị viên</span>
                </div>
                <div class="d-flex gap-2">
                    <a asp-page="/Admin/Index" class="btn btn-sm btn-outline-warning">
                        <i class="fa-solid fa-chart-line me-1"></i> Dashboard Admin
                    </a>
                    <a asp-page="/Booking/Create" class="btn btn-sm btn-outline-light">
                        <i class="fa-solid fa-house-user me-1"></i> Màn hình Staff (Home)
                    </a>
                </div>
            </div>
        </div>
    }

    <div class="card shadow border-0 rounded-3">
        <div class="card-header bg-primary text-white text-center py-3">
            <h3 class="m-0 h5 fw-bold"><i class="fa-solid fa-user-plus me-2"></i>Register Staff Account</h3>
        </div>
        <div class="card-body p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form method="post">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Full name</label>
                    <input asp-for="Input.FullName" class="form-control ps-3" placeholder="Nhập họ và tên nhân viên..." />
                    <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Phone number</label>
                    <input asp-for="Input.Phone" class="form-control ps-3" placeholder="Nhập số điện thoại đăng nhập..." />
                    <span asp-validation-for="Input.Phone" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Password</label>
                    <input asp-for="Input.Password" type="password" class="form-control ps-3" placeholder="Tối thiểu 6 ký tự..." />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Confirm Password</label>
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control ps-3" placeholder="Xác nhận lại mật khẩu..." />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button class="btn btn-primary py-2 fw-semibold"><i class="fa-solid fa-floppy-disk me-1"></i> Register Staff</button>

                    @if (currentRole != "Admin")
                    {
                        <a asp-page="/Auth/Login" class="btn btn-link text-decoration-none text-muted small text-center">
                            Already have an account? Login here
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}