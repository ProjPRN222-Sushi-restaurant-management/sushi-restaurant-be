@page
@model _290526_SushiRestaurantManagement_BE.Pages.Admin.OrderManagerModel
@using BusinessObjects.Enums

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý đơn hàng";
    ViewBag.PaginatedList = Model.Orders;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin-order-manager.css" asp-append-version="true" />
}


<div class="order-manager-page">

    <div class="order-manager-header">
        <div>
            <h2 class="order-manager-title">
                Quản lý đơn hàng
            </h2>

            <div class="order-manager-subtitle">
                Theo dõi đơn hàng, trạng thái xử lý và tổng tiền thanh toán
            </div>
        </div>

        <div class="order-badge">
            🧾 Kiểm soát đơn hàng
        </div>
    </div>

    <div class="filter-card">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-sm-5">
                <label class="form-label-custom">Tìm kiếm</label>
                <input type="text"
                       name="SearchString"
                       class="form-control"
                       placeholder="Nhập mã đơn, số điện thoại, mã đặt bàn, bàn"
                       value="@Model.SearchString" />
            </div>

            <div class="col-sm-3">
                <label class="form-label-custom">Trạng thái</label>
                <select name="StatusFilter" class="form-select">
                    <option value="">Tất cả</option>
                    @foreach (var status in Enum.GetValues<OrderStatusEnum>())
                    {
                        var selected = Model.StatusFilter == status ? "selected" : "";
                        <option value="@status" selected="@selected">@status</option>
                    }
                </select>
            </div>

            <div class="col-sm-4">
                <button type="submit" class="btn-filter w-100">
                    Lọc đơn hàng
                </button>
            </div>
        </form>
    </div>

    <div class="order-card">
        <div class="order-card-header">
            <span>Danh sách đơn hàng</span>

            <span class="order-count-badge">
                @Model.Orders.Items.Count đơn
            </span>
        </div>

        <div class="table-responsive">
            <table class="table order-table">
                <thead>
                    <tr>
                        <th class="ps-3">Mã đơn</th>
                        <th>Đặt bàn</th>
                        <th>Bàn</th>
                        <th>Khách hàng</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Nhân viên nhận</th>
                        <th>Ngày tạo</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var order in Model.Orders.Items)
                    {
                        var customer = order.Customer ?? order.Booking?.Customer;

                        <tr>
                            <td class="ps-3 order-id">
                                #@order.OrderId
                            </td>

                            <td>
                                <span class="booking-pill">
                                    @(order.BookingId.HasValue ? "#" + order.BookingId.Value : "-")
                                </span>
                            </td>

                            <td>
                                <span class="table-pill">
                                    @(order.TableId.HasValue? order.TableId.Value.ToString() : "-")
                                </span>
                            </td>

                            <td>
                                <div class="customer-name">
                                    @(customer?.FullName ?? "-")
                                </div>
                                <div class="customer-phone">
                                    @(customer?.Phone ?? "-")
                                </div>
                            </td>

                            <td>
                                <span class="amount-pill">
                                    @order.TotalAmount.ToString("N0") đ
                                </span>
                                @if (order.DiscountAmount > 0)
                                {
                                    <div class="customer-phone">
                                        @order.MembershipLevelApplied giảm @order.DiscountPercent.ToString("0.##")%
                                        (-@order.DiscountAmount.ToString("N0") đ)
                                    </div>
                                }
                            </td>

                            <td>
                                @{
                                    var orderStatusClass = order.OrderStatus switch
                                    {
                                        OrderStatusEnum.PENDING => "status-pending",
                                        OrderStatusEnum.PREPARING => "status-preparing",
                                        OrderStatusEnum.COMPLETED => "status-completed",
                                        OrderStatusEnum.CANCELLED => "status-cancelled",
                                        _ => "status-other"
                                    };
                                }

                                <span class="order-status app-status @orderStatusClass">
                                    @order.OrderStatus
                                </span>
                            </td>

                            <td>
                                @{
                                    var orderTicketStaffId = order.ReceivedStaffId ?? order.InvoiceStaffId;
                                    var orderTicketStaffName =
                                        order.ReceivedStaff?.FullName ??
                                        order.ReceivedStaffName ??
                                        order.InvoiceStaff?.FullName ??
                                        order.InvoiceStaffName;
                                }

                                @if (orderTicketStaffId.HasValue)
                                {
                                    <a asp-page="/Admin/EditStaff"
                                       asp-route-id="@orderTicketStaffId.Value"
                                       class="invoice-staff-link">
                                        @(orderTicketStaffName ?? "-")
                                    </a>
                                }
                                else if (!string.IsNullOrWhiteSpace(orderTicketStaffName))
                                {
                                    <span class="invoice-staff-muted">
                                        @orderTicketStaffName
                                    </span>
                                }
                                else
                                {
                                    <span class="invoice-staff-muted">Chưa xuất</span>
                                }
                            </td>

                            <td>
                                <span class="date-pill">
                                    @order.CreatedAt?.ToString("dd/MM/yyyy HH:mm")
                                </span>
                            </td>

                            <td class="text-center">
                                <div class="action-group">
                                    <a asp-page="/Admin/OrderDetails"
                                       asp-route-id="@order.OrderId"
                                       class="btn-view">
                                        Xem
                                    </a>

                                    <form method="post"
                                          asp-page="/Admin/OrderDetails"
                                          asp-page-handler="IssueInvoice"
                                          asp-route-id="@order.OrderId"
                                          class="m-0">
                                        <button type="submit" class="btn-print">
                                            <i class="fa-solid fa-print me-1"></i>
                                            In phiếu
                                        </button>
                                    </form>

                                    <form method="post"
                                          asp-page-handler="UpdateStatus"
                                          class="status-form">

                                        <input type="hidden"
                                               name="orderId"
                                               value="@order.OrderId" />

                                        <select name="status"
                                                class="form-select form-select-sm status-select">
                                            @foreach (var status in Enum.GetValues<OrderStatusEnum>())
                                            {
                                                var selected = order.OrderStatus == status ? "selected" : "";
                                                <option value="@status" selected="@selected">@status</option>
                                            }
                                        </select>

                                        <button type="submit" class="btn-update">
                                            Cập nhật
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }

                    @if (!Model.Orders.Items.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center empty-row">
                                Không tìm thấy đơn hàng nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.Orders.Items.Any())
    {
        <partial name="_Pagination" />
    }

</div>
