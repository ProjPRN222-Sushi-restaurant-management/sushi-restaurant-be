@page "{id:long}"
@model _290526_SushiRestaurantManagement_BE.Pages.Admin.EditCustomerModel
@using BusinessObjects.Enums
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chỉnh Sửa Khách Hàng";
}

<div class="container mt-4" style="max-width: 700px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0">Chỉnh sửa khách hàng #@Model.CustomerInfo.CustomerId</h5>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <input type="hidden" asp-for="CustomerInfo.CustomerId" />
                <input type="hidden" asp-for="CustomerInfo.CreatedAt" />
                <input type="hidden" asp-for="CustomerInfo.DeletedAt" />

                <div class="mb-3">
                    <label class="form-label">Họ và tên</label>
                    <input asp-for="CustomerInfo.FullName" class="form-control" required />
                    <span asp-validation-for="CustomerInfo.FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Số điện thoại</label>
                    <input asp-for="CustomerInfo.Phone" class="form-control" required />
                    <span asp-validation-for="CustomerInfo.Phone" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Hạng thành viên</label>
                    <select asp-for="CustomerInfo.MembershipLevel" class="form-select">
                        <option value="@MembershipLevelEnum.NONE">NONE</option>
                        <option value="@MembershipLevelEnum.SILVER">SILVER</option>
                        <option value="@MembershipLevelEnum.GOLD">GOLD</option>
                        <option value="@MembershipLevelEnum.PLATINUM">PLATINUM</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Loyalty points</label>
                    <input asp-for="CustomerInfo.LoyaltyPoints" type="number" min="0" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Trạng thái</label>
                    <input class="form-control" value="@(Model.CustomerInfo.DeletedAt == null ? "Active" : "Deleted")" disabled />
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                    <a asp-page="/Admin/CustomerManager" class="btn btn-outline-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
