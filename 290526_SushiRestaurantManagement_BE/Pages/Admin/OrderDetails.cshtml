@page "{id:int}"
@model _290526_SushiRestaurantManagement_BE.Pages.Admin.OrderDetailsModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết Order";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin-order-details.css" asp-append-version="true" />
}


<div class="order-detail-page">

    @if (Model.Order != null)
    {
        var customer = Model.Order.Customer ?? Model.Order.Booking?.Customer;
        var ticketStaffId = Model.Order.ReceivedStaffId ?? Model.Order.InvoiceStaffId;
        var ticketStaffName =
            Model.Order.ReceivedStaff?.FullName ??
            Model.Order.ReceivedStaffName ??
            Model.Order.InvoiceStaff?.FullName ??
            Model.Order.InvoiceStaffName ??
            "-";
        var ticketIssuedAt = Model.Order.ReceivedAt ?? Model.Order.InvoiceIssuedAt;
        var subtotalAmount = Model.Order.SubtotalAmount > 0
            ? Model.Order.SubtotalAmount
            : Model.Order.OrderItems.Sum(x => x.TotalPrice);
        var orderStatusClass = Model.Order.OrderStatus switch
        {
            BusinessObjects.Enums.OrderStatusEnum.PENDING => "status-pending",
            BusinessObjects.Enums.OrderStatusEnum.PREPARING => "status-preparing",
            BusinessObjects.Enums.OrderStatusEnum.COMPLETED => "status-completed",
            BusinessObjects.Enums.OrderStatusEnum.CANCELLED => "status-cancelled",
            _ => "status-other"
        };

        <div class="order-detail-header">
            <div>
                <h2 class="order-title">
                    Order #@Model.Order.OrderId
                </h2>

                <div class="order-subtitle">
                    Trạng thái:
                    <span class="status-pill app-status @orderStatusClass">
                        @Model.Order.OrderStatus
                    </span>
                </div>
            </div>

            <div class="detail-actions">
                <form method="post"
                      asp-page-handler="IssueInvoice"
                      asp-route-id="@Model.Order.OrderId"
                      class="m-0">
                    <button type="submit" class="btn-print-ticket">
                        <i class="fa-solid fa-print me-2"></i>
                        In phiếu chế biến
                    </button>
                </form>

                <a asp-page="/Admin/OrderManager" class="btn-back">
                    Quay lại danh sách
                </a>
            </div>
        </div>

        <section class="kitchen-ticket" aria-label="Phiếu chế biến">
            <h1 class="ticket-title">Phiếu chế biến</h1>

            <div class="ticket-meta">
                <div class="ticket-line">
                    <span class="ticket-label">Order</span>
                    <span>#@Model.Order.OrderId</span>
                </div>
                <div class="ticket-line">
                    <span class="ticket-label">Bàn</span>
                    <span>@(Model.Order.TableId.HasValue? Model.Order.TableId.Value.ToString() : "-")</span>
                </div>
                <div class="ticket-line">
                    <span class="ticket-label">Booking</span>
                    <span>@(Model.Order.BookingId.HasValue ? "#" + Model.Order.BookingId.Value : "-")</span>
                </div>
                <div class="ticket-line">
                    <span class="ticket-label">Giờ tạo</span>
                    <span>@Model.Order.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <div class="ticket-line">
                    <span class="ticket-label">Trạng thái</span>
                    <span class="app-status @orderStatusClass">@Model.Order.OrderStatus</span>
                </div>
                <div class="ticket-line">
                    <span class="ticket-label">Xuất bởi</span>
                    <span>@ticketStaffName</span>
                </div>
                <div class="ticket-line">
                    <span class="ticket-label">Giờ xuất</span>
                    <span>@(ticketIssuedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                </div>
            </div>

            <table class="ticket-table">
                <thead>
                    <tr>
                        <th>Món</th>
                        <th class="ticket-qty">SL</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detail in Model.Order.OrderItems)
                    {
                        <tr>
                            <td>
                                <div class="ticket-dish">
                                    @detail.MenuItem?.ItemName
                                </div>

                                @if (!string.IsNullOrWhiteSpace(detail.Note))
                                {
                                    <div class="ticket-note">
                                        @detail.Note
                                    </div>
                                }
                            </td>
                            <td class="ticket-qty">
                                @detail.Quantity
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="ticket-footer">
                Tổng @Model.Order.OrderItems.Sum(x => x.Quantity) phần
            </div>
        </section>

                <section class="order-overview-card mb-4">
            <div class="overview-header">
                <div>
                    <div class="overview-kicker">Tổng quan order</div>
                    <div class="overview-title">
                        @(customer?.FullName ?? "Khách chưa xác định")
                    </div>
                </div>

                <span class="status-pill app-status @orderStatusClass">
                    @Model.Order.OrderStatus
                </span>
            </div>

            <div class="overview-highlight-grid">
                <div class="overview-highlight important">
                    <span>Thanh toán</span>
                    <strong>@Model.Order.TotalAmount.ToString("N0") đ</strong>
                </div>

                <div class="overview-highlight">
                    <span>Booking / Bàn</span>
                    <strong>
                        @(Model.Order.BookingId.HasValue ? "#" + Model.Order.BookingId.Value : "-")
                        / @(Model.Order.TableId.HasValue ? Model.Order.TableId.Value.ToString() : "-")
                    </strong>
                </div>

                <div class="overview-highlight">
                    <span>Khách hàng</span>
                    <strong>@(customer?.Phone ?? "-")</strong>
                </div>

                <div class="overview-highlight">
                    <span>Xuất bởi</span>
                    <strong>
                        @if (ticketStaffId.HasValue)
                        {
                            <a asp-page="/Admin/EditStaff"
                               asp-route-id="@ticketStaffId.Value"
                               class="invoice-staff-link">
                                @ticketStaffName
                            </a>
                        }
                        else
                        {
                            @(ticketStaffName == "-" ? "Chưa xuất" : ticketStaffName)
                        }
                    </strong>
                </div>
            </div>

            <div class="overview-meta-grid">
                <div class="overview-meta muted">
                    <span>Ngày tạo</span>
                    <strong>@(Model.Order.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</strong>
                </div>

                <div class="overview-meta muted">
                    <span>Hoàn thành</span>
                    <strong>@(Model.Order.CompletedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</strong>
                </div>

                <div class="overview-meta muted">
                    <span>Giờ xuất</span>
                    <strong>@(ticketIssuedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</strong>
                </div>

                <div class="overview-meta">
                    <span>Tạm tính</span>
                    <strong>@subtotalAmount.ToString("N0") đ</strong>
                </div>

                <div class="overview-meta accent">
                    <span>Hạng áp dụng</span>
                    <strong>@Model.Order.MembershipLevelApplied (@Model.Order.DiscountPercent.ToString("0.##")%)</strong>
                </div>

                <div class="overview-meta danger">
                    <span>Giảm giá</span>
                    <strong>-@Model.Order.DiscountAmount.ToString("N0") đ</strong>
                </div>

                <div class="overview-meta accent">
                    <span>Điểm cộng</span>
                    <strong>@Model.Order.EarnedLoyaltyPoints điểm</strong>
                </div>

                <div class="overview-meta muted">
                    <span>Hạng / điểm hiện tại</span>
                    <strong>@(customer != null ? $"{customer.MembershipLevel} - {customer.LoyaltyPoints} điểm" : "-")</strong>
                </div>
            </div>
        </section>
        <div class="order-items-card">
            <div class="order-items-header">
                <span>Chi tiết món ăn</span>

                <span class="item-count-badge">
                    @Model.Order.OrderItems.Count món
                </span>
            </div>

            <div class="table-responsive">
                <table class="table detail-table">
                    <thead>
                        <tr>
                            <th>Món</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Tổng</th>
                            <th>Ghi chú</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var detail in Model.Order.OrderItems)
                        {
                            <tr>
                                <td class="dish-name">
                                    @detail.MenuItem?.ItemName
                                </td>

                                <td class="text-center">
                                    <span class="qty-pill">
                                        @detail.Quantity
                                    </span>
                                </td>

                                <td class="text-end">
                                    <span class="price-pill">
                                        @detail.UnitPrice.ToString("N0") đ
                                    </span>
                                </td>

                                <td class="text-end">
                                    <span class="price-pill">
                                        @detail.TotalPrice.ToString("N0") đ
                                    </span>
                                </td>

                                <td>
                                    @if (string.IsNullOrWhiteSpace(detail.Note))
                                    {
                                        <span class="text-muted fst-italic">
                                            Không có
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="note-tag">
                                            @detail.Note
                                        </span>
                                    }
                                </td>
                            </tr>
                        }

                        @if (!Model.Order.OrderItems.Any())
                        {
                            <tr>
                                <td colspan="5" class="empty-order">
                                    Order này chưa có món nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>
@section Scripts {
    @if (Model.Print)
    {
        <script>
            window.addEventListener('load', function () {
                window.print();
            });
        </script>
    }
}
