<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sushi Admin</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            min-height: 100vh;
            background: #f4f6fb;
            color: #1f2937;
        }

        .admin-sidebar {
            width: 280px;
            background: linear-gradient(180deg, #111827 0%, #1f2937 55%, #111827 100%);
            min-height: 100vh;
            color: #dee2e6;
            box-shadow: 8px 0 30px rgba(15, 23, 42, 0.18);
        }

        .sidebar-brand {
            padding: 24px 18px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .brand-icon {
            width: 46px;
            height: 46px;
            border-radius: 16px;
            background: linear-gradient(135deg, #dc2626, #fb923c);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: white;
            box-shadow: 0 12px 25px rgba(220, 38, 38, 0.35);
        }

        .brand-title {
            font-size: 1.15rem;
            font-weight: 800;
            color: #fff;
            margin: 0;
        }

        .brand-subtitle {
            font-size: 0.78rem;
            color: #9ca3af;
            margin: 0;
        }

        .admin-sidebar .nav-link {
            color: #cbd5e1;
            transition: all 0.2s ease-in-out;
            border-radius: 14px;
            margin: 4px 14px;
            padding: 12px 16px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .admin-sidebar .nav-link i {
                width: 22px;
                text-align: center;
                font-size: 1rem;
            }

            .admin-sidebar .nav-link:hover {
                color: #ffffff;
                background: rgba(255, 255, 255, 0.08);
                transform: translateX(4px);
            }

            .admin-sidebar .nav-link.active,
            .admin-sidebar .nav-link[href='@Context.Request.Path'] {
                color: #ffffff;
                background: linear-gradient(135deg, #dc2626, #f97316) !important;
                box-shadow: 0 10px 20px rgba(220, 38, 38, 0.28);
            }

        .staff-home-link {
            color: #facc15 !important;
            background: rgba(250, 204, 21, 0.08);
        }

            .staff-home-link:hover {
                background: rgba(250, 204, 21, 0.16) !important;
            }

        .sidebar-footer {
            padding: 18px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
        }

        .logout-btn {
            border-radius: 14px;
            padding: 10px;
            font-weight: 700;
        }

        .main-content {
            margin-left: 280px;
            padding: 30px;
            min-height: 100vh;
        }

        .content-card {
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid #e5e7eb;
            border-radius: 24px;
            min-height: calc(100vh - 60px);
            padding: 28px;
            box-shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
        }

        @@media (max-width: 768px) {
            .admin-sidebar {
                position: relative !important;
                width: 100%;
                min-height: auto;
            }

            .main-content {
                margin-left: 0;
                padding: 16px;
            }

            .content-card {
                padding: 18px;
                border-radius: 18px;
            }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <div class="admin-sidebar position-fixed top-0 bottom-0 start-0 z-1">

        <div class="sidebar-brand d-flex align-items-center gap-3">
            <div class="brand-icon">
                <i class="fa-solid fa-shrimp"></i>
            </div>

            <div>
                <h5 class="brand-title">Sushi Admin</h5>
                <p class="brand-subtitle">Restaurant Management</p>
            </div>
        </div>

        <div class="d-flex flex-column justify-content-between" style="height: calc(100vh - 95px);">
            <ul class="nav flex-column gap-1 pt-3">

                <li class="nav-item">
                    <a class="nav-link" asp-page="/Admin/Index">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Thống kê & Doanh thu</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-page="/Admin/StaffManager">
                        <i class="fa-solid fa-user-tie"></i>
                        <span>Quản lý Staff</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-page="/Admin/CustomerManager">
                        <i class="fa-solid fa-users"></i>
                        <span>Quản lý Customer</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-page="/Admin/OrderManager">
                        <i class="fa-solid fa-receipt"></i>
                        <span>Quản lý Orders</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-page="/Admin/MenuManager">
                        <i class="fa-solid fa-bars-progress"></i>
                        <span>Quản lý Menu</span>
                    </a>
                </li>

                <li class="nav-item mt-3 pt-3 border-top border-secondary">
                    <a class="nav-link staff-home-link" asp-page="/Booking/Create">
                        <i class="fa-solid fa-house-user"></i>
                        <span>Màn hình Staff</span>
                    </a>
                </li>

            </ul>

            <div class="sidebar-footer">
                <form method="post" asp-page="/Auth/Login" asp-page-handler="Logout">
                    <button type="submit" class="btn btn-outline-danger w-100 logout-btn">
                        <i class="fa-solid fa-power-off me-2"></i>
                        Đăng xuất
                    </button>
                </form>
            </div>
        </div>
    </div>

    <main class="main-content">
        <div class="content-card">

            @RenderBody()

        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
