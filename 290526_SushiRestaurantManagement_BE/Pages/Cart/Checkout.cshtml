@page
@model _290526_SushiRestaurantManagement_BE.Pages.Cart.CheckoutModel

<style>
    .checkout-page {
        padding: 10px 0 35px;
    }

    .checkout-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 24px;
    }

    .checkout-title {
        font-weight: 900;
        color: #991b1b;
        margin: 0;
    }

    .checkout-subtitle {
        color: #64748b;
        font-weight: 500;
        margin-top: 4px;
    }

    .checkout-badge {
        background: linear-gradient(135deg, #16a34a, #22c55e);
        color: #fff;
        border-radius: 999px;
        padding: 10px 18px;
        font-weight: 800;
        box-shadow: 0 12px 24px rgba(22, 163, 74, 0.22);
    }

    .success-alert {
        border: none;
        border-radius: 18px;
        background: linear-gradient(135deg, #dcfce7, #f0fdf4);
        color: #166534;
        font-weight: 700;
        padding: 16px 20px;
        box-shadow: 0 10px 25px rgba(22, 101, 52, 0.08);
    }

    .checkout-card {
        border: none;
        border-radius: 24px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 18px 42px rgba(15, 23, 42, 0.08);
    }

    .checkout-card-header {
        background: #fff7ed;
        border-bottom: 1px solid #fed7aa;
        padding: 18px 22px;
        font-weight: 900;
        color: #9a3412;
    }

    .checkout-table {
        margin-bottom: 0;
        vertical-align: middle;
    }

        .checkout-table thead th {
            background: #f8fafc;
            color: #475569;
            font-size: 0.88rem;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px;
        }

        .checkout-table tbody td {
            padding: 15px 14px;
            color: #334155;
        }

        .checkout-table tbody tr:hover {
            background: #fff7ed;
        }

    .item-name {
        font-weight: 800;
        color: #1f2937;
    }

    .note-text {
        color: #64748b;
        font-size: 0.92rem;
    }

    .quantity-pill {
        display: inline-flex;
        min-width: 42px;
        height: 34px;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        background: #f1f5f9;
        color: #334155;
        font-weight: 800;
    }

    .money {
        color: #dc2626;
        font-weight: 900;
    }

    .total-panel {
        margin-top: 22px;
        padding: 22px;
        border-radius: 22px;
        background: linear-gradient(135deg, #fff7ed, #ffffff);
        border: 1px solid #fed7aa;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 14px;
    }

    .total-label {
        color: #64748b;
        font-weight: 700;
    }

    .total-amount {
        font-size: 1.5rem;
        color: #dc2626;
        font-weight: 950;
    }

    .submit-area {
        margin-top: 22px;
        text-align: right;
    }

    .btn-print-ticket {
        border: none;
        border-radius: 999px;
        padding: 12px 26px;
        font-weight: 900;
        background: linear-gradient(135deg, #d97706, #f97316);
        color: #ffffff;
        box-shadow: 0 14px 28px rgba(217, 119, 6, 0.24);
        transition: all 0.2s ease;
    }

        .btn-print-ticket:hover {
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 18px 34px rgba(217, 119, 6, 0.32);
        }

    .empty-cart {
        border: none;
        border-radius: 20px;
        background: #fff7ed;
        color: #9a3412;
        padding: 20px 24px;
        font-weight: 800;
    }

    .kitchen-ticket {
        display: none;
    }

    @@media print {
        @@page {
            size: 80mm auto;
            margin: 6mm;
        }

        html,
        body {
            width: 80mm;
            margin: 0;
            padding: 0;
            background: #ffffff !important;
            color: #000000 !important;
            font-family: Arial, sans-serif;
            font-size: 11px;
        }

        body * {
            visibility: hidden !important;
        }

        .kitchen-ticket,
        .kitchen-ticket * {
            visibility: visible !important;
        }

        .kitchen-ticket {
            display: block !important;
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
        }

        .ticket-title {
            text-align: center;
            font-size: 16px;
            font-weight: 900;
            text-transform: uppercase;
            margin: 0 0 6px;
        }

        .ticket-meta {
            border-top: 1px dashed #000000;
            border-bottom: 1px dashed #000000;
            padding: 6px 0;
            margin-bottom: 8px;
        }

        .ticket-line {
            display: flex;
            justify-content: space-between;
            gap: 8px;
            margin: 2px 0;
        }

        .ticket-label {
            font-weight: 700;
        }

        .ticket-table {
            width: 100%;
            border-collapse: collapse;
        }

        .ticket-table th,
        .ticket-table td {
            border-bottom: 1px dashed #000000;
            padding: 5px 0;
            vertical-align: top;
        }

        .ticket-table th {
            font-size: 10px;
            text-transform: uppercase;
            text-align: left;
        }

        .ticket-table .ticket-qty {
            width: 24px;
            text-align: center;
            font-weight: 900;
        }

        .ticket-dish {
            font-weight: 900;
        }

        .ticket-note {
            margin-top: 2px;
            font-size: 10px;
            font-style: italic;
        }

        .ticket-footer {
            text-align: center;
            margin-top: 10px;
            padding-top: 6px;
            border-top: 1px dashed #000000;
            font-weight: 700;
        }
    }
</style>

<div class="checkout-page">

    <div class="checkout-header">
        <div>
            <h2 class="checkout-title">Xác nhận order</h2>
            <div class="checkout-subtitle">Kiểm tra món trước khi gửi order vào bếp</div>
        </div>

        <div class="checkout-badge">
            ✅ Ready to Order
        </div>
    </div>

    @if (TempData["OrderSuccess"] != null)
    {
        <div class="alert success-alert">
            @TempData["OrderSuccess"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (Model.CartItems.Any())
    {
        <section class="kitchen-ticket" aria-label="Phiếu chế biến">
            <h1 class="ticket-title">Phiếu chế biến</h1>

            <div class="ticket-meta">
                @if (Model.SavedOrder != null)
                {
                    <div class="ticket-line">
                        <span class="ticket-label">Order</span>
                        <span>#@Model.SavedOrder.OrderId</span>
                    </div>
                    <div class="ticket-line">
                        <span class="ticket-label">Trạng thái</span>
                        <span>@Model.SavedOrder.OrderStatus</span>
                    </div>
                    @if (Model.SavedOrder.TableId.HasValue)
                    {
                        <div class="ticket-line">
                            <span class="ticket-label">Bàn</span>
                            <span>@Model.SavedOrder.TableId</span>
                        </div>
                    }
                }
                <div class="ticket-line">
                    <span class="ticket-label">Số món</span>
                    <span>@((Model.SavedOrder?.CreatedAt ?? DateTime.Now).ToString("dd/MM/yyyy HH:mm"))</span>
                </div>
            </div>

            <table class="ticket-table">
                <thead>
                    <tr>
                        <th>Món</th>
                        <th class="ticket-qty">SL</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.CartItems)
                    {
                        <tr>
                            <td>
                                <div class="ticket-dish">
                                    @item.ItemName
                                </div>

                                @if (!string.IsNullOrWhiteSpace(item.Note))
                                {
                                    <div class="ticket-note">
                                        @item.Note
                                    </div>
                                }
                            </td>
                            <td class="ticket-qty">
                                @item.Quantity
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="ticket-footer">
                Dùng cho bộ phận bếp
            </div>
        </section>

        <div class="checkout-card">
            <div class="checkout-card-header">
                Danh sách món trong giỏ
            </div>

            <div class="table-responsive">
                <table class="table checkout-table">
                    <thead>
                        <tr>
                            <th>Món</th>
                            <th>Tùy chọn</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Tổng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.CartItems)
                        {
                            <tr>
                                <td class="item-name">@item.ItemName</td>
                                <td class="note-text">@item.Note</td>
                                <td class="text-center">
                                    <span class="quantity-pill">@item.Quantity</span>
                                </td>
                                <td class="text-end money">
                                    @item.Total.ToString("N0") đ
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="total-panel">
            <div>
                <div class="total-label">Tổng tiền dự kiến</div>
                <div class="text-muted small">Số tiền tạm tính trước khi thanh toán</div>
            </div>

            <div class="total-amount">
                @Model.TotalAmount.ToString("N0") đ
            </div>
        </div>

        <div class="submit-area">
            @if (Model.SavedOrder != null)
            {
                <button type="button" class="btn-print-ticket" onclick="window.print()">
                    <i class="fa-solid fa-print me-2"></i>
                    In lại phiếu chế biến
                </button>
            }
            else
            {
                <form method="post" id="sendOrderPrintForm">
                    <button type="submit" class="btn-print-ticket" id="sendOrderPrintButton">
                        <i class="fa-solid fa-print me-2"></i>
                        In phiếu chế biến
                    </button>
                </form>
            }
        </div>
    }
    else
    {
        <div class="empty-cart">
            Giỏ hàng hiện chưa có món nào để xác nhận.
        </div>
    }

</div>
@if (Model.Print && Model.SavedOrder != null)
{
    <script>
        window.addEventListener('load', function () {
            window.print();
        });
    </script>
}

<script>
    const sendOrderPrintForm = document.getElementById('sendOrderPrintForm');
    const sendOrderPrintButton = document.getElementById('sendOrderPrintButton');

    if (sendOrderPrintForm && sendOrderPrintButton) {
        sendOrderPrintForm.addEventListener('submit', function () {
            sendOrderPrintButton.disabled = true;
            sendOrderPrintButton.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i> Đang gửi order...';
        });
    }
</script>