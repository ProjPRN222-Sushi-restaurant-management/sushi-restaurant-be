@page
@model _290526_SushiRestaurantManagement_BE.Pages.Auth.ResetPasswordModel

<style>

    .reset-page {
        min-height: 78vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 35px 0;
    }

    .reset-card {
        width: 100%;
        max-width: 520px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 24px 60px rgba(15,23,42,.12);
    }

    .reset-header {
        background: linear-gradient( 135deg, #dc2626, #f97316);
        color: #ffffff;
        text-align: center;
        padding: 38px 26px;
    }

    .reset-icon {
        width: 78px;
        height: 78px;
        margin: 0 auto 16px;
        border-radius: 24px;
        background: rgba(255,255,255,.18);
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 36px;
    }

    .reset-title {
        margin: 0;
        font-weight: 900;
    }

    .reset-subtitle {
        margin-top: 6px;
        opacity: .95;
        font-weight: 500;
    }

    .reset-body {
        padding: 30px;
    }

    .error-alert {
        border: none;
        border-radius: 18px;
        padding: 15px 18px;
        background: #fee2e2;
        color: #991b1b;
        font-weight: 700;
    }

    .form-label-custom {
        color: #475569;
        font-size: .9rem;
        font-weight: 800;
        margin-bottom: 7px;
    }

    .reset-form .form-control {
        border-radius: 16px;
        border: 1px solid #dbe3ef;
        padding: 12px 14px;
        font-weight: 600;
    }

        .reset-form .form-control:focus {
            border-color: #f97316;
            box-shadow: 0 0 0 .2rem rgba(249,115,22,.15);
        }

    .btn-reset {
        width: 100%;
        border: none;
        border-radius: 999px;
        padding: 13px 24px;
        font-weight: 900;
        color: white;
        background: linear-gradient( 135deg, #16a34a, #22c55e);
        box-shadow: 0 14px 28px rgba(22,163,74,.25);
        transition: all .2s ease;
    }

        .btn-reset:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 18px 34px rgba(22,163,74,.35);
        }

    .back-login {
        display: block;
        text-align: center;
        margin-top: 18px;
        color: #64748b;
        font-weight: 800;
        text-decoration: none;
    }

        .back-login:hover {
            color: #dc2626;
        }

    @@media(max-width:576px) {

        .reset-body {
            padding: 22px;
        }
    }

</style>


<div class="reset-page">

    <div class="reset-card">

        <div class="reset-header">

            <div class="reset-icon">

                🔑

            </div>

            <h2 class="reset-title">

                Đặt lại mật khẩu

            </h2>

            <div class="reset-subtitle">

                Tạo mật khẩu mới cho tài khoản của bạn

            </div>

        </div>


        <div class="reset-body">

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert error-alert">

                    @Model.ErrorMessage

                </div>
            }

            <form method="post"
                  class="reset-form">

                <input asp-for="Input.Phone"
                       type="hidden" />

                <div class="mb-3">

                    <label class="form-label-custom">

                        Mật khẩu mới

                    </label>

                    <input asp-for="Input.NewPassword"
                           type="password"
                           class="form-control"
                           placeholder="Nhập mật khẩu mới..." />

                    <span asp-validation-for="Input.NewPassword"
                          class="text-danger small"></span>

                </div>


                <div class="mb-3">

                    <label class="form-label-custom">

                        Xác nhận mật khẩu

                    </label>

                    <input asp-for="Input.ConfirmPassword"
                           type="password"
                           class="form-control"
                           placeholder="Xác nhận lại mật khẩu..." />

                    <span asp-validation-for="Input.ConfirmPassword"
                          class="text-danger small"></span>

                </div>


                <button class="btn-reset">

                    Đặt lại mật khẩu

                </button>

                <a asp-page="/Auth/Login"
                   class="back-login">

                    Quay lại đăng nhập

                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}
