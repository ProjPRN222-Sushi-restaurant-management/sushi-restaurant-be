@page
@model _290526_SushiRestaurantManagement_BE.Pages.Menu.IndexModel

@using _290526_SushiRestaurantManagement_BE.Utilities

@section Styles {
    <link rel="stylesheet" href="~/css/pages/menu-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/menu-controls.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/menu-card-controls.css" asp-append-version="true" />
}


<div class="menu-page">

    <div class="menu-header">
        <div>
            <h2 class="menu-title">Thực đơn Sushi</h2>
            <div class="menu-subtitle">Chọn món cho booking hiện tại</div>
        </div>

        <div class="menu-badge">
            🍣 Thực đơn tươi mới
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert success-alert">
            @TempData["Success"]
        </div>
    }

    <section class="menu-toolbar" aria-label="Lọc menu">
        <form method="get" class="menu-filter-form">
            <input type="hidden" name="bookingId" value="@Model.BookingId" />
            <input type="hidden" name="tableId" value="@Model.TableId" />
            <input type="hidden" name="pageNumber" value="1" />

            <div class="menu-search-field">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="search"
                       name="searchTerm"
                       value="@Model.SearchTerm"
                       placeholder="Tìm món sushi, ramen, đồ uống..." />
            </div>

            <select name="categoryId" class="menu-category-select" aria-label="Lọc theo category">
                <option value="">Tất cả danh mục</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.CategoryId" selected="@(Model.CategoryId == category.CategoryId)">
                        @category.CategoryName
                    </option>
                }
            </select>

            <button type="submit" class="menu-filter-btn">
                <i class="fa-solid fa-filter"></i>
                Lọc
            </button>

            <a asp-page="/Menu/Index"
               asp-route-bookingId="@Model.BookingId"
               asp-route-tableId="@Model.TableId"
               class="menu-reset-btn">
                Đặt lại
            </a>
        </form>

        <div class="menu-result-summary">
            Hiển thị <strong>@Model.FirstItemNumber-@Model.LastItemNumber</strong>
            trong <strong>@Model.TotalItems</strong> món
        </div>
    </section>

    @if (!Model.MenuItems.Any())
    {
        <div class="menu-empty-state">
            Không tìm thấy món phù hợp.
        </div>
    }
    else
    {
        <div class="menu-grid">
            @foreach (var item in Model.MenuItems)
            {
                <div class="menu-card">

                    <div class="menu-image-wrap">
                        <img src="@MenuImageResolver.ResolveImageUrl(item.ItemName, item.ImageUrl)" alt="@item.ItemName" loading="lazy"
                             onerror="this.onerror=null;this.src='/images/placeholder.svg';" />
                        <div class="price-pill">
                            @item.Price.ToString("N0") đ
                        </div>
                    </div>

                    <div class="menu-content">
                        <h4 class="menu-name">@item.ItemName</h4>

                        <p class="menu-description">
                            @item.Description
                        </p>

                        <form method="post" asp-page="/Menu/Index" asp-page-handler="AddToCart"
                              class="menu-add-form" data-name="@item.ItemName">
                            <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                            <input type="hidden" name="bookingId" value="@Model.BookingId" />
                            <input type="hidden" name="tableId" value="@Model.TableId" />
                            <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                            <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                            <input type="hidden" name="pageNumber" value="@Model.PageNumber" />

                            <div class="compact-control-row">
                                <label class="form-label-custom">Số lượng</label>
                                <div class="quantity-stepper" aria-label="Số lượng">
                                    <button type="button"
                                            class="quantity-btn"
                                            data-quantity-step="-1"
                                            aria-label="Giảm số lượng">
                                        -
                                    </button>
                                    <input type="number"
                                           name="quantity"
                                           value="1"
                                           min="1"
                                           class="quantity-input" />
                                    <button type="button"
                                            class="quantity-btn"
                                            data-quantity-step="1"
                                            aria-label="Tăng số lượng">
                                        +
                                    </button>
                                </div>
                            </div>

                            <div class="compact-options-block">
                                <label class="form-label-custom">Tùy chọn món</label>
                                <input type="hidden" name="note" value="Wasabi: Có; Gừng hồng: Có" />

                                <div class="quick-option-panel">
                                    <div class="quick-option-row">
                                        <div class="quick-option-title">
                                            <i class="fa-solid fa-leaf me-1"></i>
                                            Wasabi
                                        </div>

                                        <input class="quick-switch-input"
                                               type="checkbox"
                                               id="wasabi-@item.MenuItemId"
                                               name="wasabiToggle"
                                               data-option-target="wasabi"
                                               checked />
                                        <label class="quick-switch"
                                               for="wasabi-@item.MenuItemId"
                                               aria-label="Bật tắt Wasabi">
                                            <span class="quick-switch-knob"></span>
                                        </label>
                                    </div>

                                    <div class="quick-option-row">
                                        <div class="quick-option-title">
                                            <i class="fa-solid fa-seedling me-1"></i>
                                            Gừng hồng
                                        </div>

                                        <input class="quick-switch-input"
                                               type="checkbox"
                                               id="ginger-@item.MenuItemId"
                                               name="gingerToggle"
                                               data-option-target="ginger"
                                               checked />
                                        <label class="quick-switch"
                                               for="ginger-@item.MenuItemId"
                                               aria-label="Bật tắt Gừng hồng">
                                            <span class="quick-switch-knob"></span>
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <button class="btn-add-cart">
                                Thêm vào giỏ
                            </button>
                        </form>
                    </div>

                </div>
            }
        </div>
    }

    @if (Model.TotalPages > 1)
    {
        var startPage = Math.Max(1, Model.PageNumber - 2);
        var endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);

        <nav class="menu-pagination" aria-label="Phân trang menu">
            <a class="menu-page-link @(Model.PageNumber == 1 ? "disabled" : "")"
               asp-page="/Menu/Index"
               asp-route-bookingId="@Model.BookingId"
               asp-route-tableId="@Model.TableId"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-categoryId="@Model.CategoryId"
               asp-route-pageNumber="@(Model.PageNumber - 1)">
                <i class="fa-solid fa-chevron-left"></i>
            </a>

            @for (var pageIndex = startPage; pageIndex <= endPage; pageIndex++)
            {
                <a class="menu-page-link @(pageIndex == Model.PageNumber ? "active" : "")"
                   asp-page="/Menu/Index"
                   asp-route-bookingId="@Model.BookingId"
                   asp-route-tableId="@Model.TableId"
                   asp-route-searchTerm="@Model.SearchTerm"
                   asp-route-categoryId="@Model.CategoryId"
                   asp-route-pageNumber="@pageIndex">
                    @pageIndex
                </a>
            }

            <a class="menu-page-link @(Model.PageNumber == Model.TotalPages ? "disabled" : "")"
               asp-page="/Menu/Index"
               asp-route-bookingId="@Model.BookingId"
               asp-route-tableId="@Model.TableId"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-categoryId="@Model.CategoryId"
               asp-route-pageNumber="@(Model.PageNumber + 1)">
                <i class="fa-solid fa-chevron-right"></i>
            </a>
        </nav>
    }

</div>

<div class="floating-cart">
    <div class="cart-panel" id="cartPanel" hidden>
        <div class="cart-panel-header">
            <span><i class="fa-solid fa-basket-shopping me-2"></i>Giỏ hàng của bạn</span>
            <button type="button" class="cart-panel-close" id="cartPanelClose" aria-label="Đóng">&times;</button>
        </div>

        <div class="cart-panel-body" id="cartPanelBody"></div>

        <div class="cart-panel-footer">
            <div class="cart-panel-total">
                <span>Tổng cộng</span>
                <strong id="cartPanelTotal">0 đ</strong>
            </div>

            <a class="cart-checkout-btn" id="cartCheckoutBtn"
               asp-page="/Cart/Index"
               asp-route-bookingId="@Model.BookingId"
               asp-route-tableId="@Model.TableId">
                <i class="fa-solid fa-cart-shopping"></i>
                Đến giỏ hàng
            </a>
        </div>
    </div>

    <button type="button" class="cart-fab" id="cartFab" aria-label="Giỏ hàng">
        <i class="fa-solid fa-cart-shopping"></i>
        <span class="cart-fab-badge" id="cartFabBadge" hidden>0</span>
    </button>
</div>

<div class="cart-toast" id="cartToast" hidden></div>

@Html.AntiForgeryToken()

@{
    var initialCart = new
    {
        count = Model.CartItems.Sum(x => x.Quantity),
        totalAmount = Model.CartItems.Sum(x => x.Total),
        items = Model.CartItems.Select(x => new
        {
            menuItemId = x.MenuItemId,
            itemName = x.ItemName,
            quantity = x.Quantity,
            unitPrice = x.UnitPrice,
            total = x.Total,
            note = x.Note
        })
    };
}
<script id="cartInitData" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(initialCart))</script>

@section Scripts {
    <script>
        (function () {
            var fab = document.getElementById('cartFab');
            var badge = document.getElementById('cartFabBadge');
            var panel = document.getElementById('cartPanel');
            var panelBody = document.getElementById('cartPanelBody');
            var panelTotal = document.getElementById('cartPanelTotal');
            var checkoutBtn = document.getElementById('cartCheckoutBtn');
            var closeBtn = document.getElementById('cartPanelClose');
            var toastEl = document.getElementById('cartToast');
            var toastTimer = null;

            var antiforgeryToken = (document.querySelector('input[name="__RequestVerificationToken"]') || {}).value || '';
            var removeUrl = '@Url.Page("/Menu/Index", "RemoveFromCart")';

            function formatMoney(n) {
                return Number(n || 0).toLocaleString('vi-VN') + ' đ';
            }

            function escapeHtml(s) {
                return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
                    return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
                });
            }

            function renderCart(data) {
                data = data || {};
                var count = data.count || 0;

                if (count > 0) {
                    badge.textContent = count > 99 ? '99+' : count;
                    badge.hidden = false;
                } else {
                    badge.hidden = true;
                }

                panelTotal.textContent = formatMoney(data.totalAmount);

                var items = data.items || [];
                if (!items.length) {
                    panelBody.innerHTML = '<div class="cart-empty">Giỏ hàng đang trống</div>';
                    checkoutBtn.classList.add('disabled');
                    return;
                }

                var html = '';
                items.forEach(function (it) {
                    html += '<div class="cart-line">'
                        + '<div class="cart-line-info">'
                        + '<div class="cart-line-name">' + escapeHtml(it.itemName) + '</div>'
                        + (it.note ? '<div class="cart-line-note">' + escapeHtml(it.note) + '</div>' : '')
                        + '<div class="cart-line-meta">' + formatMoney(it.unitPrice) + ' × ' + it.quantity + '</div>'
                        + '</div>'
                        + '<div class="cart-line-total">' + formatMoney(it.total) + '</div>'
                        + '<button type="button" class="cart-line-remove" data-id="' + it.menuItemId + '" data-note="' + escapeHtml(it.note) + '" aria-label="Xóa món" title="Xóa món">&times;</button>'
                        + '</div>';
                });
                panelBody.innerHTML = html;
                checkoutBtn.classList.remove('disabled');
            }

            function bump() {
                fab.classList.remove('bump');
                void fab.offsetWidth;
                fab.classList.add('bump');
            }

            function showToast(msg) {
                toastEl.innerHTML = '<i class="fa-solid fa-circle-check toast-ic"></i><span>' + escapeHtml(msg) + '</span>';
                toastEl.hidden = false;
                if (toastTimer) clearTimeout(toastTimer);
                toastTimer = setTimeout(function () { toastEl.hidden = true; }, 2200);
            }

            function syncStructuredNote(form) {
                var noteEl = form.querySelector('input[name="note"]');
                if (!noteEl) return;

                var wasabiToggle = form.querySelector('input[data-option-target="wasabi"]');
                var gingerToggle = form.querySelector('input[data-option-target="ginger"]');
                var wasabi = !wasabiToggle || wasabiToggle.checked ? 'Có' : 'Không';
                var ginger = !gingerToggle || gingerToggle.checked ? 'Có' : 'Không';
                noteEl.value = 'Wasabi: ' + wasabi + '; Gừng hồng: ' + ginger;
            }

            function resetQuickOptions(form) {
                var wasabiToggle = form.querySelector('input[data-option-target="wasabi"]');
                var gingerToggle = form.querySelector('input[data-option-target="ginger"]');
                if (wasabiToggle) wasabiToggle.checked = true;
                if (gingerToggle) gingerToggle.checked = true;
                syncStructuredNote(form);
            }

            function removeItem(id, note) {
                var body = new URLSearchParams();
                body.append('menuItemId', id);
                body.append('note', note || '');

                fetch(removeUrl, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': antiforgeryToken
                    },
                    body: body.toString()
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data && data.success) {
                        renderCart(data);
                    }
                })
                .catch(function () { });
            }

            try {
                var initEl = document.getElementById('cartInitData');
                if (initEl) renderCart(JSON.parse(initEl.textContent));
            } catch (e) { }

            fab.addEventListener('click', function (e) {
                e.stopPropagation();
                panel.hidden = !panel.hidden;
            });
            closeBtn.addEventListener('click', function () { panel.hidden = true; });
            document.addEventListener('click', function (e) {
                if (!panel.hidden && !panel.contains(e.target) && !fab.contains(e.target)) {
                    panel.hidden = true;
                }
            });

            panelBody.addEventListener('click', function (e) {
                var btn = e.target.closest('.cart-line-remove');
                if (!btn) return;
                removeItem(btn.getAttribute('data-id'), btn.getAttribute('data-note') || '');
            });

            document.querySelectorAll('form.menu-add-form').forEach(function (form) {
                syncStructuredNote(form);

                form.querySelectorAll('input[data-option-target]').forEach(function (input) {
                    input.addEventListener('change', function () {
                        syncStructuredNote(form);
                    });
                });

                form.querySelectorAll('[data-quantity-step]').forEach(function (button) {
                    button.addEventListener('click', function () {
                        var qtyEl = form.querySelector('input[name="quantity"]');
                        if (!qtyEl) return;

                        var step = Number(button.getAttribute('data-quantity-step') || 0);
                        var min = Number(qtyEl.getAttribute('min') || 1);
                        var nextValue = Math.max(min, Number(qtyEl.value || min) + step);
                        qtyEl.value = nextValue;
                    });
                });

                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    syncStructuredNote(form);

                    var btn = form.querySelector('.btn-add-cart');
                    var original = btn ? btn.innerHTML : '';
                    if (btn) { btn.disabled = true; btn.innerHTML = 'Đang thêm...'; }

                    fetch(form.action, {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        body: new FormData(form)
                    })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (!data || !data.success) {
                            if (btn) { btn.innerHTML = original; btn.disabled = false; }
                            return;
                        }

                        renderCart(data);
                        bump();
                        showToast('Đã thêm ' + (form.getAttribute('data-name') || 'món') + ' vào giỏ');

                        resetQuickOptions(form);
                        var qtyEl = form.querySelector('input[name="quantity"]');
                        if (qtyEl) qtyEl.value = 1;

                        if (btn) {
                            btn.innerHTML = '<i class="fa-solid fa-check me-1"></i>Đã thêm';
                            setTimeout(function () { btn.innerHTML = original; btn.disabled = false; }, 1000);
                        }
                    })
                    .catch(function () {
                        if (btn) { btn.disabled = false; }
                        form.submit();
                    });
                });
            });
        })();
    </script>
}

