@page
@model _290526_SushiRestaurantManagement_BE.Pages.Auth.ForgotPasswordModel

<style>
    .forgot-page {
        min-height: 78vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 35px 0;
    }

    .forgot-card {
        width: 100%;
        max-width: 520px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
    }

    .forgot-header {
        background: linear-gradient(135deg, #dc2626, #f97316);
        color: #ffffff;
        text-align: center;
        padding: 38px 26px;
    }

    .forgot-icon {
        width: 78px;
        height: 78px;
        margin: 0 auto 16px;
        border-radius: 24px;
        background: rgba(255, 255, 255, .18);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
    }

    .forgot-title {
        margin: 0;
        font-weight: 900;
    }

    .forgot-subtitle {
        margin-top: 6px;
        opacity: .95;
        font-weight: 500;
    }

    .forgot-body {
        padding: 30px;
    }

    .info-alert {
        border: none;
        border-radius: 18px;
        padding: 15px 18px;
        font-weight: 700;
        background: linear-gradient(135deg, #ecfeff, #eff6ff);
        color: #155e75;
    }

    .form-label-custom {
        color: #475569;
        font-size: .9rem;
        font-weight: 800;
        margin-bottom: 7px;
    }

    .forgot-form .form-control {
        border-radius: 16px;
        border: 1px solid #dbe3ef;
        padding: 12px 14px;
        font-weight: 600;
    }

        .forgot-form .form-control:focus {
            border-color: #f97316;
            box-shadow: 0 0 0 .2rem rgba(249, 115, 22, .15);
        }

    .btn-continue {
        width: 100%;
        border: none;
        border-radius: 999px;
        padding: 13px 24px;
        font-weight: 900;
        color: #ffffff;
        background: linear-gradient(135deg, #dc2626, #f97316);
        box-shadow: 0 14px 28px rgba(220, 38, 38, .25);
        transition: all .2s ease;
    }

        .btn-continue:hover {
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 18px 34px rgba(220, 38, 38, .34);
        }

    .back-login {
        display: block;
        margin-top: 16px;
        text-align: center;
        color: #64748b;
        font-weight: 800;
        text-decoration: none;
    }

        .back-login:hover {
            color: #dc2626;
        }
</style>

<div class="forgot-page">
    <div class="forgot-card">

        <div class="forgot-header">
            <div class="forgot-icon">🔐</div>
            <h2 class="forgot-title">Forgot Password</h2>
            <div class="forgot-subtitle">
                Nhập số điện thoại để tiếp tục đặt lại mật khẩu
            </div>
        </div>

        <div class="forgot-body">

            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert info-alert">
                    @Model.Message
                </div>
            }

            <form method="post" class="forgot-form">
                <div class="mb-3">
                    <label class="form-label-custom">Enter your phone</label>
                    <input asp-for="Phone"
                           class="form-control"
                           placeholder="Nhập số điện thoại..." />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <button class="btn-continue">
                    Continue
                </button>

                <a asp-page="/Auth/Login" class="back-login">
                    Back to login
                </a>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}