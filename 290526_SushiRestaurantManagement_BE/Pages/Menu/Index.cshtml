@page
@model _290526_SushiRestaurantManagement_BE.Pages.Menu.IndexModel

@functions {
    // Map tên món -> tên file ảnh thực tế trong wwwroot/images/
    static readonly Dictionary<string, string> ImageMap = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Salmon Sushi"]    = "salmon-sushi.png",
        ["Tuna Sushi"]      = "tuna-sushi.png",
        ["Salmon Sashimi"]  = "salmon-sashimi.png",
        ["Tuna Sashimi"]    = "tuna-sashimi.png",
        ["Ebi Nigiri"]      = "ebi-nigiri.png",
        ["California Roll"]  = "California-roll.png",
        ["Tonkotsu Ramen"]  = "tonkotsu-ramen.png",
        ["Tempura Udon"]    = "tempura-udon.png",
        ["Shrimp Tempura"]  = "shrimp-tempura.png",
        ["Matcha Latte"]    = "match-latte.png",
        ["Sakura Tea"]      = "sakura-tea.png",
        ["Mochi Ice Cream"] = "mochi-ice-cream.png",
    };

    // Ưu tiên map theo tên món (khớp file ảnh thực tế); nếu không có thì
    // dùng image_url trong DB; cuối cùng là ảnh placeholder.
    static string ResolveImageUrl(string? itemName, string? imageUrl)
    {
        if (!string.IsNullOrWhiteSpace(itemName) && ImageMap.TryGetValue(itemName.Trim(), out var file))
            return "/images/" + file;

        if (string.IsNullOrWhiteSpace(imageUrl))
            return "/images/placeholder.svg";
        if (imageUrl.StartsWith("http://") || imageUrl.StartsWith("https://") || imageUrl.StartsWith("/"))
            return imageUrl;
        return "/" + imageUrl.TrimStart('~', '/');
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/menu-index.css" asp-append-version="true" />
}


<div class="menu-page">

    <div class="menu-header">
        <div>
            <h2 class="menu-title">Menu Sushi</h2>
            <div class="menu-subtitle">Chọn món cho booking hiện tại</div>
        </div>

        <div class="menu-badge">
            🍣 Fresh Menu
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert success-alert">
            @TempData["Success"]
        </div>
    }

    <div class="menu-grid">
        @foreach (var item in Model.MenuItems)
        {
            <div class="menu-card">

                <div class="menu-image-wrap">
                    <img src="@ResolveImageUrl(item.ItemName, item.ImageUrl)" alt="@item.ItemName" loading="lazy"
                         onerror="this.onerror=null;this.src='/images/placeholder.svg';" />
                    <div class="price-pill">
                        @item.Price.ToString("N0") đ
                    </div>
                </div>

                <div class="menu-content">
                    <h4 class="menu-name">@item.ItemName</h4>

                    <p class="menu-description">
                        @item.Description
                    </p>

                    <form method="post" asp-page="/Menu/Index" asp-page-handler="AddToCart"
                          class="menu-add-form" data-name="@item.ItemName">
                        <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                        <input type="hidden" name="bookingId" value="@Model.BookingId" />
                        <input type="hidden" name="tableId" value="@Model.TableId" />

                        <div class="mb-3">
                            <label class="form-label-custom">Số lượng</label>
                            <input type="number" name="quantity" value="1" min="1" class="form-control" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label-custom">Tùy chọn món</label>
                            <input type="hidden" name="note" value="Wasabi: Có; Gừng hồng: Có" />

                            <div class="quick-option-panel">
                                <div class="quick-option-group">
                                    <div class="quick-option-title">
                                        <i class="fa-solid fa-leaf me-1"></i>
                                        Wasabi
                                    </div>

                                    <div class="quick-options" role="radiogroup" aria-label="Wasabi">
                                        <input class="quick-option-input"
                                               type="radio"
                                               id="wasabi-@item.MenuItemId-co"
                                               name="wasabiOption"
                                               value="Có"
                                               checked />
                                        <label class="quick-option-label" for="wasabi-@item.MenuItemId-co">Có</label>

                                        <input class="quick-option-input"
                                               type="radio"
                                               id="wasabi-@item.MenuItemId-khong"
                                               name="wasabiOption"
                                               value="Không" />
                                        <label class="quick-option-label" for="wasabi-@item.MenuItemId-khong">Không</label>
                                    </div>
                                </div>

                                <div class="quick-option-group">
                                    <div class="quick-option-title">
                                        <i class="fa-solid fa-seedling me-1"></i>
                                        Gừng hồng
                                    </div>

                                    <div class="quick-options" role="radiogroup" aria-label="Gừng hồng">
                                        <input class="quick-option-input"
                                               type="radio"
                                               id="ginger-@item.MenuItemId-co"
                                               name="gingerOption"
                                               value="Có"
                                               checked />
                                        <label class="quick-option-label" for="ginger-@item.MenuItemId-co">Có</label>

                                        <input class="quick-option-input"
                                               type="radio"
                                               id="ginger-@item.MenuItemId-khong"
                                               name="gingerOption"
                                               value="Không" />
                                        <label class="quick-option-label" for="ginger-@item.MenuItemId-khong">Không</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <button class="btn-add-cart">
                            Thêm vào giỏ
                        </button>
                    </form>
                </div>

            </div>
        }
    </div>

</div>

<!-- ===== Giỏ hàng nổi (floating cart) ===== -->
<div class="floating-cart">
    <div class="cart-panel" id="cartPanel" hidden>
        <div class="cart-panel-header">
            <span><i class="fa-solid fa-basket-shopping me-2"></i>Giỏ hàng của bạn</span>
            <button type="button" class="cart-panel-close" id="cartPanelClose" aria-label="Đóng">&times;</button>
        </div>

        <div class="cart-panel-body" id="cartPanelBody"></div>

        <div class="cart-panel-footer">
            <div class="cart-panel-total">
                <span>Tổng cộng</span>
                <strong id="cartPanelTotal">0 đ</strong>
            </div>

            <a class="cart-checkout-btn" id="cartCheckoutBtn"
               asp-page="/Cart/Index"
               asp-route-bookingId="@Model.BookingId"
               asp-route-tableId="@Model.TableId">
                <i class="fa-solid fa-credit-card"></i>
                Thanh toán
            </a>
        </div>
    </div>

    <button type="button" class="cart-fab" id="cartFab" aria-label="Giỏ hàng">
        <i class="fa-solid fa-cart-shopping"></i>
        <span class="cart-fab-badge" id="cartFabBadge" hidden>0</span>
    </button>
</div>

<div class="cart-toast" id="cartToast" hidden></div>

@Html.AntiForgeryToken()

@{
    var initialCart = new
    {
        count = Model.CartItems.Sum(x => x.Quantity),
        totalAmount = Model.CartItems.Sum(x => x.Total),
        items = Model.CartItems.Select(x => new
        {
            menuItemId = x.MenuItemId,
            itemName = x.ItemName,
            quantity = x.Quantity,
            unitPrice = x.UnitPrice,
            total = x.Total,
            note = x.Note
        })
    };
}
<script id="cartInitData" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(initialCart))</script>

@section Scripts {
    <script>
        (function () {
            var fab = document.getElementById('cartFab');
            var badge = document.getElementById('cartFabBadge');
            var panel = document.getElementById('cartPanel');
            var panelBody = document.getElementById('cartPanelBody');
            var panelTotal = document.getElementById('cartPanelTotal');
            var checkoutBtn = document.getElementById('cartCheckoutBtn');
            var closeBtn = document.getElementById('cartPanelClose');
            var toastEl = document.getElementById('cartToast');
            var toastTimer = null;

            var antiforgeryToken = (document.querySelector('input[name="__RequestVerificationToken"]') || {}).value || '';
            var removeUrl = '@Url.Page("/Menu/Index", "RemoveFromCart")';

            function formatMoney(n) {
                return Number(n || 0).toLocaleString('vi-VN') + ' đ';
            }

            function escapeHtml(s) {
                return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
                    return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
                });
            }

            function renderCart(data) {
                data = data || {};
                var count = data.count || 0;

                if (count > 0) {
                    badge.textContent = count > 99 ? '99+' : count;
                    badge.hidden = false;
                } else {
                    badge.hidden = true;
                }

                panelTotal.textContent = formatMoney(data.totalAmount);

                var items = data.items || [];
                if (!items.length) {
                    panelBody.innerHTML = '<div class="cart-empty">Giỏ hàng đang trống</div>';
                    checkoutBtn.classList.add('disabled');
                    return;
                }

                var html = '';
                items.forEach(function (it) {
                    html += '<div class="cart-line">'
                        + '<div class="cart-line-info">'
                        + '<div class="cart-line-name">' + escapeHtml(it.itemName) + '</div>'
                        + (it.note ? '<div class="cart-line-note">' + escapeHtml(it.note) + '</div>' : '')
                        + '<div class="cart-line-meta">' + formatMoney(it.unitPrice) + ' × ' + it.quantity + '</div>'
                        + '</div>'
                        + '<div class="cart-line-total">' + formatMoney(it.total) + '</div>'
                        + '<button type="button" class="cart-line-remove" data-id="' + it.menuItemId + '" data-note="' + escapeHtml(it.note) + '" aria-label="Xóa món" title="Xóa món">&times;</button>'
                        + '</div>';
                });
                panelBody.innerHTML = html;
                checkoutBtn.classList.remove('disabled');
            }

            function bump() {
                fab.classList.remove('bump');
                void fab.offsetWidth;
                fab.classList.add('bump');
            }

            function showToast(msg) {
                toastEl.innerHTML = '<i class="fa-solid fa-circle-check toast-ic"></i><span>' + escapeHtml(msg) + '</span>';
                toastEl.hidden = false;
                if (toastTimer) clearTimeout(toastTimer);
                toastTimer = setTimeout(function () { toastEl.hidden = true; }, 2200);
            }

            function getCheckedValue(form, name) {
                var input = form.querySelector('input[name="' + name + '"]:checked');
                return input ? input.value : '';
            }

            function syncStructuredNote(form) {
                var noteEl = form.querySelector('input[name="note"]');
                if (!noteEl) return;

                var wasabi = getCheckedValue(form, 'wasabiOption') || 'Có';
                var ginger = getCheckedValue(form, 'gingerOption') || 'Có';
                noteEl.value = 'Wasabi: ' + wasabi + '; Gừng hồng: ' + ginger;
            }

            function resetQuickOptions(form) {
                var wasabiYes = form.querySelector('input[name="wasabiOption"][value="Có"]');
                var gingerYes = form.querySelector('input[name="gingerOption"][value="Có"]');
                if (wasabiYes) wasabiYes.checked = true;
                if (gingerYes) gingerYes.checked = true;
                syncStructuredNote(form);
            }

            function removeItem(id, note) {
                var body = new URLSearchParams();
                body.append('menuItemId', id);
                body.append('note', note || '');

                fetch(removeUrl, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': antiforgeryToken
                    },
                    body: body.toString()
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data && data.success) {
                        renderCart(data);
                    }
                })
                .catch(function () { });
            }

            // Khởi tạo trạng thái giỏ hàng từ dữ liệu server
            try {
                var initEl = document.getElementById('cartInitData');
                if (initEl) renderCart(JSON.parse(initEl.textContent));
            } catch (e) { }

            // Đóng / mở panel giỏ hàng
            fab.addEventListener('click', function (e) {
                e.stopPropagation();
                panel.hidden = !panel.hidden;
            });
            closeBtn.addEventListener('click', function () { panel.hidden = true; });
            document.addEventListener('click', function (e) {
                if (!panel.hidden && !panel.contains(e.target) && !fab.contains(e.target)) {
                    panel.hidden = true;
                }
            });

            // Xóa món khỏi giỏ (nút ×)
            panelBody.addEventListener('click', function (e) {
                var btn = e.target.closest('.cart-line-remove');
                if (!btn) return;
                removeItem(btn.getAttribute('data-id'), btn.getAttribute('data-note') || '');
            });

            // Thêm vào giỏ bằng AJAX -> không reload trang, không nhảy về đầu trang
            document.querySelectorAll('form.menu-add-form').forEach(function (form) {
                syncStructuredNote(form);

                form.querySelectorAll('input[name="wasabiOption"], input[name="gingerOption"]').forEach(function (input) {
                    input.addEventListener('change', function () {
                        syncStructuredNote(form);
                    });
                });

                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    syncStructuredNote(form);

                    var btn = form.querySelector('.btn-add-cart');
                    var original = btn ? btn.innerHTML : '';
                    if (btn) { btn.disabled = true; btn.innerHTML = 'Đang thêm...'; }

                    fetch(form.action, {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        body: new FormData(form)
                    })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (!data || !data.success) {
                            if (btn) { btn.innerHTML = original; btn.disabled = false; }
                            return;
                        }

                        renderCart(data);
                        bump();
                        showToast('Đã thêm ' + (form.getAttribute('data-name') || 'món') + ' vào giỏ');

                        resetQuickOptions(form);
                        var qtyEl = form.querySelector('input[name="quantity"]');
                        if (qtyEl) qtyEl.value = 1;

                        if (btn) {
                            btn.innerHTML = '<i class="fa-solid fa-check me-1"></i>Đã thêm';
                            setTimeout(function () { btn.innerHTML = original; btn.disabled = false; }, 1000);
                        }
                    })
                    .catch(function () {
                        // AJAX lỗi -> quay về submit thường (fallback)
                        if (btn) { btn.disabled = false; }
                        form.submit();
                    });
                });
            });
        })();
    </script>
}
