@page
@model _290526_SushiRestaurantManagement_BE.Pages.Auth.LoginModel

<h2>Login</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post">
    <div class="mb-3">
        <label>Phone</label>
        <input asp-for="Input.Phone" class="form-control" />
        <span asp-validation-for="Input.Phone" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Password</label>
        <input asp-for="Input.Password" type="password" class="form-control" />
        <span asp-validation-for="Input.Password" class="text-danger"></span>
    </div>

    <button class="btn btn-primary">Login</button>

    <a asp-page="/Auth/ForgotPassword" class="btn btn-link">Forgot password?</a>
    <a asp-page="/Auth/Register" class="btn btn-link">Register</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
