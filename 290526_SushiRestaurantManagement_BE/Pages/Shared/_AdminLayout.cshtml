<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sushi Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        .admin-sidebar {
            background-color: #1e2229;
            min-height: 100vh;
            color: #dee2e6;
        }

            .admin-sidebar .nav-link {
                color: #aaaaaa;
                transition: all 0.2s ease-in-out;
                border-radius: 6px;
                margin: 2px 12px;
                font-weight: 500;
            }

                .admin-sidebar .nav-link:hover {
                    color: #ffffff;
                    background-color: #2b313c;
                }

                .admin-sidebar .nav-link.active,
                .admin-sidebar .nav-link[href='@Context.Request.Path'] {
                    color: #ffffff;
                    background-color: #0d6efd !important; 
                }

        .main-content {
            padding: 30px;
            min-height: 100vh;
        }
    </style>
</head>
<body class="bg-light">
    <div class="container-fluid p-0">
        <div class="row g-0">

            <div class="col-md-3 col-lg-2 admin-sidebar position-fixed top-0 bottom-0 start-0 z-1 shadow">
                <div class="p-3 text-center border-bottom border-secondary mb-3">
                    <h5 class="m-0 text-white fw-bold">
                        <i class="fa-solid fa-shrimp text-danger me-2"></i>Sushi Admin
                    </h5>
                </div>

                <div class="d-flex flex-column justify-content-between" style="height: calc(100vh - 85px);">
                    <ul class="nav flex-column gap-1">
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2.5" asp-page="/Admin/Index">
                                <i class="fa-solid fa-chart-line me-2"></i>Thống kê & Doanh thu
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2.5" asp-page="/Admin/StaffManager">
                                <i class="fa-solid fa-user-tie me-2"></i>Quản lý Staff
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2.5" asp-page="/Admin/CustomerManager">
                                <i class="fa-solid fa-users me-2"></i>Quản lý Customer
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2.5" asp-page="/Admin/MenuManager">
                                <i class="fa-solid fa-bars-progress me-2"></i>Quản lý Menu
                            </a>
                        </li>
                        <li class="nav-item mt-3 border-top border-secondary pt-2">
                            <a class="nav-link px-3 py-2.5 text-warning" asp-page="/Booking/Create">
                                <i class="fa-solid fa-house-user me-2"></i>Màn hình Staff (Home)
                            </a>
                        </li>
                    </ul>

                    <div class="p-3 border-top border-secondary">
                        <form method="post" asp-page="/Auth/Login" asp-page-handler="Logout">
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100 py-2 fw-semibold">
                                <i class="fa-solid fa-power-off me-2"></i>Đăng xuất
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-9 ms-sm-auto col-lg-10 main-content">
                @RenderBody()
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>