@using Microsoft.AspNetCore.Http

@{
    var isLoggedIn = Context.Session.GetString("StaffId") != null;
    var staffPhone = Context.Session.GetString("StaffPhone") ?? "";

    // Check acc admin
    var isAdmin = isLoggedIn && staffPhone == "0999999999";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sushi Restaurant</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            min-height: 100vh;
            background: radial-gradient(circle at top left, rgba(220, 38, 38, 0.12), transparent 35%), linear-gradient(135deg, #fff7ed 0%, #fff 45%, #f8fafc 100%);
            color: #1f2937;
        }

        .app-navbar {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid rgba(229, 231, 235, 0.9);
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
        }

        .brand-box {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.35rem;
            font-weight: 800;
            color: #991b1b;
            letter-spacing: -0.5px;
        }

        .brand-icon {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            background: linear-gradient(135deg, #dc2626, #f97316);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            box-shadow: 0 10px 20px rgba(220, 38, 38, 0.25);
        }

        .nav-menu {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-left: 28px;
        }

            .nav-menu .nav-link {
                color: #475569;
                font-weight: 600;
                padding: 9px 15px;
                border-radius: 999px;
                transition: all 0.2s ease;
            }

                .nav-menu .nav-link:hover {
                    color: #dc2626;
                    background: #fee2e2;
                    transform: translateY(-1px);
                }

        .admin-link {
            color: #b91c1c !important;
            background: #fee2e2;
        }

        .user-panel {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-badge {
            padding: 8px 14px;
            border-radius: 999px;
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            font-size: 0.92rem;
            color: #334155;
        }

        .admin-badge {
            color: #dc2626;
            font-weight: 700;
        }

        .logout-btn {
            border-radius: 999px;
            padding: 8px 16px;
            font-weight: 600;
        }

        .page-shell {
            background: rgba(255, 255, 255, 0.78);
            border: 1px solid rgba(229, 231, 235, 0.85);
            border-radius: 26px;
            box-shadow: 0 20px 55px rgba(15, 23, 42, 0.08);
            padding: 28px;
            margin-top: 24px;
            margin-bottom: 70px;
        }

        .app-footer {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(12px);
            border-top: 1px solid #e5e7eb;
            padding: 18px 0;
        }

        @@media (max-width: 768px) {
            .nav-wrapper {
                flex-direction: column;
                align-items: flex-start !important;
                gap: 16px;
            }

            .nav-menu {
                margin-left: 0;
                flex-wrap: wrap;
            }

            .user-panel {
                width: 100%;
                justify-content: space-between;
                flex-wrap: wrap;
            }

            .page-shell {
                padding: 18px;
                border-radius: 18px;
            }
        }
    </style>
</head>

<body>

    @if (isLoggedIn)
    {
        <header>
            <nav class="navbar app-navbar mb-3">
                <div class="container nav-wrapper d-flex align-items-center">

                    <div class="brand-box">
                        <div class="brand-icon">🍣</div>
                        <span>Sushi Restaurant</span>
                    </div>

                    <div class="nav-menu">
                        <a class="nav-link" asp-page="/Booking/Create">Booking</a>
                        <a class="nav-link" asp-page="/Menu/Index">Menu</a>
                        <a class="nav-link" asp-page="/Cart/Index">Cart</a>
                        <a class="nav-link" asp-page="/Booking/Availability">Management status</a>

                        @if (isAdmin)
                        {
                            <a class="nav-link admin-link fw-bold" asp-page="/Admin/Index">Dashboard</a>
                        }
                    </div>

                    <div class="ms-auto user-panel">
                        <div class="user-badge">
                            Hello, <strong>@Context.Session.GetString("StaffName")</strong>
                            @if (isAdmin)
                            {
                                <span class="admin-badge">(Admin)</span>
                            }
                        </div>

                        <form method="post" asp-page="/Auth/Login" asp-page-handler="Logout" class="d-inline">
                            <button type="submit" class="btn btn-outline-danger btn-sm logout-btn">
                                Logout
                            </button>
                        </form>
                    </div>

                </div>
            </nav>
        </header>
    }

    <main role="main" class="container pb-3">
        <div class="page-shell">
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer text-muted">
        <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>&copy; 2026 - Sushi Restaurant</span>
            <span>Fresh sushi, smooth service.</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>