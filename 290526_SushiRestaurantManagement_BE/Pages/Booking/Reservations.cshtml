@page
@model _290526_SushiRestaurantManagement_BE.Pages.Booking.ReservationsModel
@using BusinessObjects.Enums

@{
    ViewData["Title"] = "Đơn đã đặt";
    ViewBag.PaginatedList = Model.Orders;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/booking-availability.css" asp-append-version="true" />
}

<div class="availability-page">
    <div class="availability-header">
        <div>
            <h2 class="availability-title">Đơn đã đặt</h2>
            <div class="availability-subtitle">
                Theo dõi toàn bộ order có booking và order mua mang đi theo ngày
            </div>
        </div>

        <div class="availability-badge">
            Đơn hàng
        </div>
    </div>

    <div class="filter-card">
        <form method="get" class="filter-form">
            <div>
                <label for="selectedDate" class="form-label-custom">
                    Chọn ngày
                </label>

                <input type="date"
                       id="selectedDate"
                       name="selectedDate"
                       class="form-control"
                       value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
            </div>

            <button type="submit" class="btn-filter">
                Xem
            </button>
        </form>
    </div>

    <div class="section-card">
        <div class="section-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>
                Danh sách đơn đã đặt - @Model.SelectedDate.ToString("dd/MM/yyyy")
            </span>

            <span class="booking-count-badge">
                @Model.Orders.TotalItems đơn
            </span>
        </div>

        @if (!Model.Orders.Items.Any())
        {
            <div class="empty-booking">
                Không có order nào trong ngày này.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table availability-table compact-table">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Loại đơn</th>
                            <th>Khách hàng</th>
                            <th>SĐT</th>
                            <th>Thời gian</th>
                            <th>Bàn</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var order in Model.Orders.Items)
                        {
                            var customerName =
                                order.Customer?.FullName ??
                                order.Booking?.GuestName ??
                                "Khách lẻ";
                            var customerPhone =
                                order.Customer?.Phone ??
                                order.Booking?.GuestPhone ??
                                "";
                            var tableLabel =
                                order.Table?.TableNum ??
                                order.TableId?.ToString() ??
                                "";
                            var orderTotal = order.TotalAmount > 0
                                ? order.TotalAmount
                                : order.SubtotalAmount > 0
                                    ? order.SubtotalAmount - order.DiscountAmount
                                    : order.OrderItems.Sum(item => item.TotalPrice);
                            var statusClass = order.OrderStatus switch
                            {
                                OrderStatusEnum.PENDING => "status-pending",
                                OrderStatusEnum.PREPARING => "status-preparing",
                                OrderStatusEnum.COMPLETED => "status-completed",
                                OrderStatusEnum.CANCELLED => "status-cancelled",
                                _ => "status-other"
                            };

                            <tr>
                                <td class="fw-bold text-danger">#@order.OrderId</td>
                                <td>
                                    @if (order.BookingId.HasValue)
                                    {
                                        <span class="source-pill source-booking">
                                            Đặt bàn #@order.BookingId
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="source-pill source-direct">
                                            Mua mang đi
                                        </span>
                                    }
                                </td>
                                <td class="fw-bold">@customerName</td>
                                <td>@customerPhone</td>
                                <td>@(order.CreatedAt?.ToString("HH:mm") ?? "")</td>
                                <td>@tableLabel</td>
                                <td class="order-amount">@orderTotal.ToString("N0") đ</td>
                                <td>
                                    <span class="booking-status app-status @statusClass">@order.OrderStatus</span>
                                </td>

                                <td>
                                    <div class="action-group">
                                        @if (order.BookingId.HasValue)
                                        {
                                            <a asp-page="/Order/History"
                                               asp-route-bookingId="@order.BookingId"
                                               class="btn-action btn-history">
                                                Xem order
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-page="/Order/History"
                                               asp-route-orderId="@order.OrderId"
                                               class="btn-action btn-history">
                                                Xem order
                                            </a>
                                        }

                                        <a asp-page="/Menu/Index"
                                           asp-route-bookingId="@order.BookingId"
                                           asp-route-tableId="@order.TableId"
                                           class="btn-action btn-order">
                                            Gọi thêm món
                                        </a>

                                        <form method="post"
                                              asp-page-handler="UpdateStatus"
                                              class="status-form">

                                            <input type="hidden"
                                                   name="orderId"
                                                   value="@order.OrderId" />

                                            <input type="hidden"
                                                   name="selectedDate"
                                                   value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />

                                            <input type="hidden"
                                                   name="pageNumber"
                                                   value="@Model.PageNumber" />

                                            <select name="status"
                                                    class="form-select form-select-sm status-select">
                                                @foreach (var status in Enum.GetValues<OrderStatusEnum>())
                                                {
                                                    var selected = order.OrderStatus == status ? "selected" : null;
                                                    <option value="@status" selected="@selected">@status</option>
                                                }
                                            </select>

                                            <button type="submit" class="btn-action btn-update">
                                                Cập nhật
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <partial name="_Pagination" />
        }
    </div>
</div>
