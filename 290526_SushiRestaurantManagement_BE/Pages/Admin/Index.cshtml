@* @page
@model _290526_SushiRestaurantManagement_BE.Pages.Admin.IndexModel
@{
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <h2 class="h3 mb-0 text-gray-800">Bảng Thống Kê Hệ Thống</h2>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body bg-white rounded">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-bold text-secondary small">Từ ngày</label>
                <input type="date" name="StartDate" class="form-control" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-secondary small">Đến ngày</label>
                <input type="date" name="EndDate" class="form-control" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100"><i class="fa-solid fa-filter me-1"></i> Lọc dữ liệu</button>
                <a asp-page="/Admin/Index" class="btn btn-outline-secondary w-100">Xóa bộ lọc</a>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-start border-primary border-4 shadow-sm h-100 py-2">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1" style="font-size: 0.8rem;">Tổng lượt đặt bàn (Giai đoạn)</div>
                        <div class="h3 mb-0 fw-bold text-gray-800">@Model.TotalBookingsCount</div>
                    </div>
                    <i class="fa-solid fa-calendar-check fa-2x text-primary opacity-25"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-start border-success border-4 shadow-sm h-100 py-2">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1" style="font-size: 0.8rem;">Số bàn trống hiện tại</div>
                        <div class="h3 mb-0 fw-bold text-gray-800">@Model.AvailableTablesCount</div>
                    </div>
                    <i class="fa-solid fa-table-cells fa-2x text-success opacity-25"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-start border-warning border-4 shadow-sm h-100 py-2">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1" style="font-size: 0.8rem;">Thu nhập (Giai đoạn)</div>
                        <div class="h3 mb-0 fw-bold text-danger">@Model.MonthlyRevenue.ToString("N0") VNĐ</div>
                    </div>
                    <i class="fa-solid fa-coins fa-2x text-warning opacity-25"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 fw-bold text-dark border-bottom">
        <i class="fa-solid fa-list-check me-2 text-secondary"></i>Danh sách đặt bàn trong khoảng thời gian lọc
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Mã Booking</th>
                    <th>Ngày đặt</th>
                    <th>Khách Hàng</th>
                    <th>Số Điện Thoại</th>
                    <th>Thời Gian Đến</th>
                    <th>Số Khách</th>
                    <th class="pe-3">Trạng Thái</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.FilteredBookings == null || !Model.FilteredBookings.Items.Any())
                {
                    <tr>
                        <td colspan=\"7\" class=\"text-center py-4 text-muted\">Không có lượt đặt bàn nào trong thời gian này.</td>
                    </tr>
                }
                else
                {
                    @foreach (var b in Model.FilteredBookings.Items)
                    {
                        <tr>
                            <td class="ps-3">#@b.BookingId</td>
                            <td>@b.BookingDate.ToString("dd/MM/yyyy")</td>
                            <td><strong>@b.GuestName</strong></td>
                            <td>@b.GuestPhone</td>
                            <td>@b.BookingTime.ToString("HH:mm")</td>
                            <td>@b.GuestCount người</td>
                            <td class="pe-3">
                                <span class="badge @(b.BookingStatus == BusinessObjects.Enums.BookingStatusEnum.PENDING ? "bg-warning text-dark" : b.BookingStatus == BusinessObjects.Enums.BookingStatusEnum.CANCELLED ? "bg-danger" : "bg-success")">
                                    @b.BookingStatus
                                </span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@{
    ViewBag.PaginatedList = Model.FilteredBookings;
}

<partial name="_Pagination" /> *@
@page
@model _290526_SushiRestaurantManagement_BE.Pages.Admin.IndexModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Trang Tổng Quan";
    ViewBag.PaginatedList = Model.FilteredBookings;
}

<style>
    .dashboard-page {
        padding: 4px 0 30px;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 24px;
    }

    .dashboard-title {
        margin: 0;
        color: #991b1b;
        font-weight: 900;
    }

    .dashboard-subtitle {
        margin-top: 4px;
        color: #64748b;
        font-weight: 500;
    }

    .dashboard-badge {
        padding: 10px 18px;
        border-radius: 999px;
        color: #fff;
        font-weight: 900;
        background: linear-gradient(135deg, #dc2626, #f97316);
        box-shadow: 0 14px 28px rgba(220, 38, 38, .24);
    }

    .filter-card,
    .metric-card,
    .booking-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        box-shadow: 0 18px 42px rgba(15, 23, 42, .08);
    }

    .filter-card {
        padding: 22px;
        margin-bottom: 24px;
    }

    .form-label-custom {
        color: #475569;
        font-size: .86rem;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 7px;
    }

    .filter-card .form-control {
        border-radius: 16px;
        border: 1px solid #dbe3ef;
        padding: 11px 14px;
        font-weight: 600;
    }

        .filter-card .form-control:focus {
            border-color: #f97316;
            box-shadow: 0 0 0 .2rem rgba(249, 115, 22, .15);
        }

    .filter-actions {
        display: flex;
        gap: 10px;
    }

    .btn-filter,
    .btn-clear {
        border: none;
        border-radius: 999px;
        padding: 11px 20px;
        font-weight: 900;
        text-decoration: none;
        transition: all .2s ease;
    }

    .btn-filter {
        color: #ffffff;
        background: linear-gradient(135deg, #dc2626, #f97316);
        box-shadow: 0 12px 24px rgba(220, 38, 38, .22);
    }

        .btn-filter:hover {
            color: #ffffff;
            transform: translateY(-2px);
        }

    .btn-clear {
        color: #334155;
        background: #f1f5f9;
    }

        .btn-clear:hover {
            color: #0f172a;
            background: #e2e8f0;
            transform: translateY(-2px);
        }

    .metric-card {
        padding: 24px;
        height: 100%;
        overflow: hidden;
        position: relative;
    }

    .metric-label {
        color: #64748b;
        font-size: .82rem;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .metric-value {
        color: #1f2937;
        font-size: 1.9rem;
        font-weight: 950;
    }

        .metric-value.revenue {
            color: #dc2626;
            font-size: 1.55rem;
        }

    .metric-icon {
        position: absolute;
        right: 22px;
        bottom: 18px;
        font-size: 3rem;
        opacity: .13;
    }

    .metric-booking {
        border-left: 6px solid #2563eb;
    }

    .metric-table {
        border-left: 6px solid #16a34a;
    }

    .metric-revenue {
        border-left: 6px solid #f59e0b;
    }

    .metric-booking .metric-icon {
        color: #2563eb;
    }

    .metric-table .metric-icon {
        color: #16a34a;
    }

    .metric-revenue .metric-icon {
        color: #f59e0b;
    }

    .booking-card {
        overflow: hidden;
        margin-top: 24px;
    }

    .booking-card-header {
        padding: 18px 22px;
        background: #fff7ed;
        border-bottom: 1px solid #fed7aa;
        color: #9a3412;
        font-weight: 900;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
    }

    .booking-count-badge {
        padding: 8px 14px;
        border-radius: 999px;
        background: #fee2e2;
        color: #991b1b;
        font-weight: 900;
        font-size: .85rem;
    }

    .booking-table {
        margin-bottom: 0;
        vertical-align: middle;
    }

        .booking-table thead th {
            background: #f8fafc;
            color: #475569;
            font-size: .86rem;
            text-transform: uppercase;
            letter-spacing: .3px;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px;
        }

        .booking-table tbody td {
            padding: 15px 14px;
            color: #334155;
        }

        .booking-table tbody tr:hover {
            background: #fff7ed;
        }

    .booking-id {
        color: #dc2626;
        font-weight: 900;
    }

    .guest-name {
        color: #1f2937;
        font-weight: 900;
    }

    .phone-pill,
    .guest-pill,
    .time-pill,
    .booking-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 7px 12px;
        font-size: .84rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .phone-pill {
        background: #f8fafc;
        color: #334155;
        border: 1px solid #e5e7eb;
    }

    .time-pill {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .guest-pill {
        background: #fff7ed;
        color: #9a3412;
    }

    .status-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .status-completed {
        background: #dcfce7;
        color: #166534;
    }

    .status-cancelled {
        background: #fee2e2;
        color: #991b1b;
    }

    .empty-row {
        padding: 30px;
        color: #64748b;
        font-weight: 800;
    }

    @@media (max-width: 768px) {
        .filter-actions {
            flex-direction: column;
        }

        .btn-filter,
        .btn-clear {
            width: 100%;
            text-align: center;
        }
    }
</style>

<div class="dashboard-page">

    <div class="dashboard-header">
        <div>
            <h2 class="dashboard-title">
                Bảng Thống Kê Hệ Thống
            </h2>
            <div class="dashboard-subtitle">
                Theo dõi lượt đặt bàn, bàn trống và doanh thu theo giai đoạn
            </div>
        </div>

        <div class="dashboard-badge">
            📊 Admin
        </div>
    </div>

    <div class="filter-card">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label-custom">Từ ngày</label>
                <input type="date"
                       name="StartDate"
                       class="form-control"
                       value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-md-4">
                <label class="form-label-custom">Đến ngày</label>
                <input type="date"
                       name="EndDate"
                       class="form-control"
                       value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-md-4">
                <div class="filter-actions">
                    <button type="submit" class="btn-filter w-100">
                        <i class="fa-solid fa-filter me-1"></i>
                        Lọc dữ liệu
                    </button>

                    <a asp-page="/Admin/Index" class="btn-clear w-100">
                        Xóa bộ lọc
                    </a>
                </div>
            </div>
        </form>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="metric-card metric-booking">
                <div class="metric-label">
                    Tổng lượt đặt bàn
                </div>
                <div class="metric-value">
                    @Model.TotalBookingsCount
                </div>
                <i class="fa-solid fa-calendar-check metric-icon"></i>
            </div>
        </div>

        <div class="col-md-4">
            <div class="metric-card metric-table">
                <div class="metric-label">
                    Số bàn trống hiện tại
                </div>
                <div class="metric-value">
                    @Model.AvailableTablesCount
                </div>
                <i class="fa-solid fa-table-cells metric-icon"></i>
            </div>
        </div>

        <div class="col-md-4">
            <div class="metric-card metric-revenue">
                <div class="metric-label">
                    Thu nhập
                </div>
                <div class="metric-value revenue">
                    @Model.MonthlyRevenue.ToString("N0") VNĐ
                </div>
                <i class="fa-solid fa-coins metric-icon"></i>
            </div>
        </div>
    </div>

    <div class="booking-card">
        <div class="booking-card-header">
            <span>
                <i class="fa-solid fa-list-check me-2"></i>
                Danh sách đặt bàn trong khoảng thời gian lọc
            </span>

            <span class="booking-count-badge">
                @(Model.FilteredBookings?.Items.Count ?? 0) booking
            </span>
        </div>

        <div class="table-responsive">
            <table class="table booking-table">
                <thead>
                    <tr>
                        <th class="ps-3">Mã Booking</th>
                        <th>Ngày đặt</th>
                        <th>Khách Hàng</th>
                        <th>Số Điện Thoại</th>
                        <th>Thời Gian Đến</th>
                        <th>Số Khách</th>
                        <th class="pe-3">Trạng Thái</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.FilteredBookings == null || !Model.FilteredBookings.Items.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center empty-row">
                                Không có lượt đặt bàn nào trong thời gian này.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var b in Model.FilteredBookings.Items)
                        {
                            <tr>
                                <td class="ps-3 booking-id">
                                    #@b.BookingId
                                </td>

                                <td>
                                    @b.BookingDate.ToString("dd/MM/yyyy")
                                </td>

                                <td class="guest-name">
                                    @b.GuestName
                                </td>

                                <td>
                                    <span class="phone-pill">
                                        @b.GuestPhone
                                    </span>
                                </td>

                                <td>
                                    <span class="time-pill">
                                        @b.BookingTime.ToString("HH:mm")
                                    </span>
                                </td>

                                <td>
                                    <span class="guest-pill">
                                        @b.GuestCount người
                                    </span>
                                </td>

                                <td class="pe-3">
                                    @{
                                        var bookingStatusClass = b.BookingStatus switch
                                        {
                                            BusinessObjects.Enums.BookingStatusEnum.PENDING => "status-pending",
                                            BusinessObjects.Enums.BookingStatusEnum.PREPARING => "status-preparing",
                                            BusinessObjects.Enums.BookingStatusEnum.COMPLETED => "status-completed",
                                            BusinessObjects.Enums.BookingStatusEnum.CANCELLED => "status-cancelled",
                                            _ => "status-other"
                                        };
                                    }

                                    <span class="booking-status app-status @bookingStatusClass">
                                        @b.BookingStatus
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.FilteredBookings != null && Model.FilteredBookings.Items.Any())
    {
        <partial name="_Pagination" />
    }

</div>
