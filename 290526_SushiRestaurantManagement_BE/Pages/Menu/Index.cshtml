@page
@model _290526_SushiRestaurantManagement_BE.Pages.Menu.IndexModel

<h2>Menu Sushi</h2>

<div class="menu-grid">
    @foreach (var item in Model.MenuItems)
    {
        <div class="menu-card">
            <img src="@item.ImageUrl" alt="@item.ItemName" style="width:100%;height:180px;object-fit:cover;" />

            <h4>@item.ItemName</h4>
            <p>@item.Description</p>
            <strong>@item.Price.ToString("N0") đ</strong>

            <form method="post" asp-page="/Cart/Index" asp-page-handler="Add">
                <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                <input type="hidden" name="bookingId" value="@Model.BookingId" />
                <input type="hidden" name="tableId" value="@Model.TableId" />

                <label>Số lượng</label>
                <input type="number" name="quantity" value="1" min="1" class="form-control" />

                <label>Tùy chọn</label>
                <textarea name="note" class="form-control"
                      placeholder="Không wasabi, ít cơm, thêm gừng, dị ứng hải sản..."></textarea>

                <button class="btn btn-primary mt-2">Thêm vào giỏ</button>
            </form>
        </div>
    }
</div>
