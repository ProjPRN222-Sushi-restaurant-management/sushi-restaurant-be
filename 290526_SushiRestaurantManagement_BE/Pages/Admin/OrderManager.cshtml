@page
@model _290526_SushiRestaurantManagement_BE.Pages.Admin.OrderManagerModel
@using BusinessObjects.Enums

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản Lý Orders";
    ViewBag.PaginatedList = Model.Orders;
}

<style>
    .order-manager-page {
        padding: 4px 0 30px;
    }

    .order-manager-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 24px;
    }

    .order-manager-title {
        margin: 0;
        color: #991b1b;
        font-weight: 900;
    }

    .order-manager-subtitle {
        margin-top: 4px;
        color: #64748b;
        font-weight: 500;
    }

    .order-badge {
        padding: 10px 18px;
        border-radius: 999px;
        color: #fff;
        font-weight: 900;
        background: linear-gradient(135deg, #dc2626, #f97316);
        box-shadow: 0 14px 28px rgba(220, 38, 38, .24);
    }

    .filter-card,
    .order-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        box-shadow: 0 18px 42px rgba(15, 23, 42, .08);
    }

    .filter-card {
        padding: 22px;
        margin-bottom: 24px;
    }

    .form-label-custom {
        color: #475569;
        font-size: .86rem;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 7px;
    }

    .filter-card .form-control,
    .filter-card .form-select {
        border-radius: 16px;
        border: 1px solid #dbe3ef;
        padding: 11px 14px;
        font-weight: 600;
    }

        .filter-card .form-control:focus,
        .filter-card .form-select:focus,
        .status-select:focus {
            border-color: #f97316;
            box-shadow: 0 0 0 .2rem rgba(249, 115, 22, .15);
        }

    .btn-filter {
        border: none;
        border-radius: 999px;
        padding: 11px 22px;
        color: #ffffff;
        font-weight: 900;
        background: linear-gradient(135deg, #111827, #374151);
        transition: all .2s ease;
    }

        .btn-filter:hover {
            color: #ffffff;
            transform: translateY(-2px);
        }

    .order-card {
        overflow: hidden;
    }

    .order-card-header {
        padding: 18px 22px;
        background: #fff7ed;
        border-bottom: 1px solid #fed7aa;
        color: #9a3412;
        font-weight: 900;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .order-count-badge {
        padding: 8px 14px;
        border-radius: 999px;
        background: #fee2e2;
        color: #991b1b;
        font-weight: 900;
        font-size: .85rem;
    }

    .order-table {
        margin-bottom: 0;
        vertical-align: middle;
    }

        .order-table thead th {
            background: #f8fafc;
            color: #475569;
            font-size: .86rem;
            text-transform: uppercase;
            letter-spacing: .3px;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px;
        }

        .order-table tbody td {
            padding: 15px 14px;
            color: #334155;
        }

        .order-table tbody tr:hover {
            background: #fff7ed;
        }

    .order-id {
        color: #dc2626;
        font-weight: 900;
    }

    .customer-name {
        color: #1f2937;
        font-weight: 900;
    }

    .customer-phone {
        color: #64748b;
        font-size: .84rem;
        font-weight: 700;
    }

    .booking-pill,
    .table-pill,
    .amount-pill,
    .date-pill,
    .order-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 7px 12px;
        font-size: .84rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .booking-pill {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .table-pill {
        background: #f8fafc;
        color: #334155;
        border: 1px solid #e5e7eb;
    }

    .amount-pill {
        background: #fff7ed;
        color: #dc2626;
        font-weight: 900;
    }

    .date-pill {
        background: #f8fafc;
        color: #475569;
        border: 1px solid #e5e7eb;
    }

    .status-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .status-completed {
        background: #dcfce7;
        color: #166534;
    }

    .status-cancelled,
    .status-other {
        background: #fee2e2;
        color: #991b1b;
    }

    .action-group {
        display: flex;
        justify-content: center;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
    }

    .btn-view,
    .btn-update {
        border: none;
        border-radius: 999px;
        padding: 8px 14px;
        font-size: .84rem;
        font-weight: 900;
        text-decoration: none;
        transition: all .18s ease;
        white-space: nowrap;
    }

    .btn-view {
        background: #eff6ff;
        color: #1d4ed8;
    }

        .btn-view:hover {
            background: #2563eb;
            color: #ffffff;
        }

    .btn-update {
        background: #dcfce7;
        color: #166534;
    }

        .btn-update:hover {
            background: #16a34a;
            color: #ffffff;
        }

    .status-form {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin: 0;
    }

    .status-select {
        width: 135px;
        border-radius: 999px;
        font-weight: 700;
        border: 1px solid #dbe3ef;
    }

    .empty-row {
        padding: 30px;
        color: #64748b;
        font-weight: 800;
    }

    @@media (max-width: 768px) {
        .btn-filter {
            width: 100%;
        }

        .status-form {
            flex-wrap: wrap;
            justify-content: center;
        }

        .status-select,
        .btn-update {
            width: 100%;
        }
    }
</style>

<div class="order-manager-page">

    <div class="order-manager-header">
        <div>
            <h2 class="order-manager-title">
                Quản Lý Orders
            </h2>

            <div class="order-manager-subtitle">
                Theo dõi đơn hàng, trạng thái xử lý và tổng tiền thanh toán
            </div>
        </div>

        <div class="order-badge">
            🧾 Order Control
        </div>
    </div>

    <div class="filter-card">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-sm-5">
                <label class="form-label-custom">Tìm kiếm</label>
                <input type="text"
                       name="SearchString"
                       class="form-control"
                       placeholder="Nhập ID, số điện thoại, booking, table"
                       value="@Model.SearchString" />
            </div>

            <div class="col-sm-3">
                <label class="form-label-custom">Trạng thái</label>
                <select name="StatusFilter" class="form-select">
                    <option value="">Tất cả</option>
                    @foreach (var status in Enum.GetValues<OrderStatusEnum>())
                    {
                        var selected = Model.StatusFilter == status ? "selected" : "";
                        <option value="@status" selected="@selected">@status</option>
                    }
                </select>
            </div>

            <div class="col-sm-4">
                <button type="submit" class="btn-filter w-100">
                    Lọc orders
                </button>
            </div>
        </form>
    </div>

    <div class="order-card">
        <div class="order-card-header">
            <span>Danh sách orders</span>

            <span class="order-count-badge">
                @Model.Orders.Items.Count orders
            </span>
        </div>

        <div class="table-responsive">
            <table class="table order-table">
                <thead>
                    <tr>
                        <th class="ps-3">Order ID</th>
                        <th>Booking</th>
                        <th>Table</th>
                        <th>Customer</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var order in Model.Orders.Items)
                    {
                        <tr>
                            <td class="ps-3 order-id">
                                #@order.OrderId
                            </td>

                            <td>
                                <span class="booking-pill">
                                    @(order.BookingId.HasValue ? "#" + order.BookingId.Value : "-")
                                </span>
                            </td>

                            <td>
                                <span class="table-pill">
                                    @(order.TableId.HasValue? order.TableId.Value.ToString() : "-")
                                </span>
                            </td>

                            <td>
                                <div class="customer-name">
                                    @(order.Customer?.FullName ?? "-")
                                </div>
                                <div class="customer-phone">
                                    @(order.Customer?.Phone ?? "-")
                                </div>
                            </td>

                            <td>
                                <span class="amount-pill">
                                    @order.TotalAmount.ToString("N0") đ
                                </span>
                            </td>

                            <td>
                                @if (order.OrderStatus == OrderStatusEnum.PENDING)
                                {
                                    <span class="order-status status-pending">
                                        @order.OrderStatus
                                    </span>
                                }
                                else if (order.OrderStatus == OrderStatusEnum.COMPLETED)
                                {
                                    <span class="order-status status-completed">
                                        @order.OrderStatus
                                    </span>
                                }
                                else
                                {
                                    <span class="order-status status-cancelled">
                                        @order.OrderStatus
                                    </span>
                                }
                            </td>

                            <td>
                                <span class="date-pill">
                                    @order.CreatedAt?.ToString("dd/MM/yyyy HH:mm")
                                </span>
                            </td>

                            <td class="text-center">
                                <div class="action-group">
                                    <a asp-page="/Admin/OrderDetails"
                                       asp-route-id="@order.OrderId"
                                       class="btn-view">
                                        Xem
                                    </a>

                                    <form method="post"
                                          asp-page-handler="UpdateStatus"
                                          class="status-form">

                                        <input type="hidden"
                                               name="orderId"
                                               value="@order.OrderId" />

                                        <select name="status"
                                                class="form-select form-select-sm status-select">
                                            @foreach (var status in Enum.GetValues<OrderStatusEnum>())
                                            {
                                                var selected = order.OrderStatus == status ? "selected" : "";
                                                <option value="@status" selected="@selected">@status</option>
                                            }
                                        </select>

                                        <button type="submit" class="btn-update">
                                            Cập nhật
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }

                    @if (!Model.Orders.Items.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center empty-row">
                                Không tìm thấy order nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.Orders.Items.Any())
    {
        <partial name="_Pagination" />
    }

</div>