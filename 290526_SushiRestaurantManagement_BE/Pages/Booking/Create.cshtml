@page
@model _290526_SushiRestaurantManagement_BE.Pages.Booking.CreateModel
@using BusinessObjects.Enums

<style>
    .booking-page {
        padding: 10px 0 35px;
    }

    .booking-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 24px;
    }

    .booking-title {
        font-weight: 900;
        color: #991b1b;
        margin: 0;
    }

    .booking-subtitle {
        color: #64748b;
        font-weight: 500;
        margin-top: 4px;
    }

    .booking-badge {
        background: linear-gradient(135deg, #dc2626, #f97316);
        color: #fff;
        border-radius: 999px;
        padding: 10px 18px;
        font-weight: 800;
        box-shadow: 0 12px 24px rgba(220, 38, 38, 0.22);
    }

    .booking-layout {
        display: grid;
        grid-template-columns: 1.3fr 0.9fr;
        gap: 24px;
        align-items: start;
    }

    .booking-card,
    .status-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        box-shadow: 0 18px 42px rgba(15, 23, 42, 0.08);
        overflow: hidden;
    }

    .booking-card-header,
    .status-card-header {
        background: #fff7ed;
        border-bottom: 1px solid #fed7aa;
        padding: 18px 22px;
        font-weight: 900;
        color: #9a3412;
    }

    .booking-card-body,
    .status-card-body {
        padding: 24px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
    }

    .form-group-full {
        grid-column: 1 / -1;
    }

    .form-label-custom {
        color: #475569;
        font-size: 0.9rem;
        font-weight: 800;
        margin-bottom: 7px;
    }

    .booking-form .form-control,
    .booking-form .form-select {
        border-radius: 15px;
        border: 1px solid #dbe3ef;
        padding: 11px 13px;
        color: #1f2937;
        font-weight: 600;
    }

        .booking-form .form-control:focus,
        .booking-form .form-select:focus {
            border-color: #f97316;
            box-shadow: 0 0 0 0.2rem rgba(249, 115, 22, 0.15);
        }

    .booking-form textarea {
        min-height: 100px;
        resize: vertical;
    }

    .validation-alert {
        border: none;
        border-radius: 18px;
        background: #fee2e2;
        color: #991b1b;
        padding: 16px 20px;
        font-weight: 800;
        box-shadow: 0 10px 25px rgba(153, 27, 27, 0.08);
        margin-bottom: 20px;
    }

    .available-summary {
        margin-top: 22px;
        padding: 18px 20px;
        border-radius: 20px;
        background: linear-gradient(135deg, #ecfdf5, #ffffff);
        border: 1px solid #bbf7d0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .available-summary-label {
        color: #166534;
        font-weight: 800;
    }

    .available-count {
        font-size: 1.6rem;
        color: #16a34a;
        font-weight: 950;
    }

    .table-list,
    .booking-list {
        list-style: none;
        padding-left: 0;
        margin: 0;
        display: grid;
        gap: 10px;
    }

    .table-item {
        padding: 13px 15px;
        border-radius: 16px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #14532d;
        font-weight: 700;
    }

    .booking-item {
        padding: 13px 15px;
        border-radius: 16px;
        background: #fffbeb;
        border: 1px solid #fde68a;
        color: #92400e;
        font-weight: 700;
    }

    .empty-table-alert {
        border: none;
        border-radius: 18px;
        background: #fee2e2;
        color: #991b1b;
        padding: 16px 20px;
        font-weight: 800;
        margin-bottom: 18px;
    }

    .existing-booking-alert {
        margin-top: 18px;
        border-radius: 20px;
        background: #fffbeb;
        border: 1px solid #fde68a;
        padding: 18px;
    }

    .existing-title {
        color: #92400e;
        font-weight: 900;
        margin-bottom: 12px;
    }

    .btn-booking-submit {
        margin-top: 24px;
        border: none;
        border-radius: 999px;
        padding: 13px 28px;
        font-weight: 900;
        color: #ffffff;
        background: linear-gradient(135deg, #dc2626, #f97316);
        box-shadow: 0 14px 28px rgba(220, 38, 38, 0.25);
        transition: all 0.2s ease;
    }

        .btn-booking-submit:hover {
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 18px 34px rgba(220, 38, 38, 0.34);
        }

    @@media (max-width: 992px) {
        .booking-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 576px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .booking-card-body,
        .status-card-body {
            padding: 18px;
        }

        .btn-booking-submit {
            width: 100%;
        }
    }
</style>

<div class="booking-page">

    <div class="booking-header">
        <div>
            <h2 class="booking-title">
                Đặt bàn Sushi
            </h2>
            <div class="booking-subtitle">
                Chọn ngày, giờ và khu vực phù hợp cho khách
            </div>
        </div>

        <div class="booking-badge">
            🍣 New Booking
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="validation-alert">
            Vui lòng kiểm tra lại thông tin đặt bàn.
        </div>
    }

    <form method="post" class="booking-form">
        <div class="booking-layout">

            <div class="booking-card">
                <div class="booking-card-header">
                    Thông tin đặt bàn
                </div>

                <div class="booking-card-body">
                    <div class="form-grid">

                        <div>
                            <label class="form-label-custom">Ngày đặt</label>
                            <input asp-for="Input.BookingDate" type="date" class="form-control" />
                        </div>

                        <div>
                            <label class="form-label-custom">Giờ đặt</label>
                            <input asp-for="Input.BookingTime" type="time" class="form-control" />
                        </div>

                        <div>
                            <label class="form-label-custom">Số người lớn</label>
                            <input asp-for="Input.AdultCount" type="number" min="1" class="form-control" />
                        </div>

                        <div>
                            <label class="form-label-custom">Số trẻ em</label>
                            <input asp-for="Input.ChildCount" type="number" min="0" class="form-control" />
                        </div>

                        <div class="form-group-full">
                            <label class="form-label-custom">Khu vực mong muốn</label>
                            <select asp-for="Input.TableType" class="form-control">
                                <option value="@TableTypeEnum.NORMAL">Bàn thường</option>
                                <option value="@TableTypeEnum.BAR">Quầy bar xem đầu bếp làm sushi</option>
                                <option value="@TableTypeEnum.VIP">VIP</option>
                            </select>
                        </div>

                        <div>
                            <label class="form-label-custom">Họ tên</label>
                            <input asp-for="Input.GuestName" class="form-control" />
                        </div>

                        <div>
                            <label class="form-label-custom">Số điện thoại</label>
                            <input asp-for="Input.GuestPhone" class="form-control" />
                        </div>

                        <div class="form-group-full">
                            <label class="form-label-custom">Ghi chú</label>
                            <textarea asp-for="Input.Note"
                                      class="form-control"
                                      placeholder="Tiệc sinh nhật, cần ghế trẻ em, dị ứng..."></textarea>
                        </div>

                    </div>

                    <div class="available-summary">
                        <div>
                            <div class="available-summary-label">
                                Bàn phù hợp hiện có
                            </div>
                            <div class="text-muted small">
                                Dựa trên ngày, giờ và khu vực đã chọn
                            </div>
                        </div>

                        <div class="available-count">
                            @Model.AvailableTableCount
                        </div>
                    </div>

                    <button type="submit" class="btn-booking-submit">
                        Xác nhận đặt bàn
                    </button>
                </div>
            </div>

            <div class="status-card">
                <div class="status-card-header">
                    Tình trạng bàn
                </div>

                <div class="status-card-body">

                    @if (Model.AvailableTables.Any())
                    {
                        <div class="mb-3 fw-bold text-success">
                            Các bàn còn trống
                        </div>

                        <ul class="table-list">
                            @foreach (var table in Model.AvailableTables)
                            {
                                <li class="table-item">
                                    Bàn @table.TableNum -
                                    Sức chứa: @table.Capacity -
                                    Loại: @table.TableType
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="empty-table-alert">
                            Khung giờ này đã hết bàn phù hợp.
                        </div>
                    }

                    @if (Model.ExistingBookings.Any())
                    {
                        <div class="existing-booking-alert">
                            <div class="existing-title">
                                Khung giờ này đã có người đặt
                            </div>

                            <ul class="booking-list">
                                @foreach (var booking in Model.ExistingBookings)
                                {
                                    <li class="booking-item">
                                        Bàn ID: @booking.TableId -
                                        Khách: @booking.GuestName -
                                        SĐT: @booking.GuestPhone
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                </div>
            </div>

        </div>
    </form>

</div>