@page
@model _290526_SushiRestaurantManagement_BE.Pages.Admin.IndexModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Trang Tổng Quan";
    ViewBag.PaginatedList = Model.FilteredOrders;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin-index.css" asp-append-version="true" />
}


<div class="dashboard-page">

    <div class="dashboard-header">
        <div>
            <h2 class="dashboard-title">
                Bảng Thống Kê Hệ Thống
            </h2>
            <div class="dashboard-subtitle">
                Theo dõi lượt đặt bàn, bàn trống và doanh thu theo giai đoạn
            </div>
        </div>

        <div class="dashboard-badge">
            📊 Quản trị
        </div>
    </div>

    <div class="filter-card">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label-custom">Từ ngày</label>
                <input type="date"
                       name="StartDate"
                       class="form-control"
                       value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-md-4">
                <label class="form-label-custom">Đến ngày</label>
                <input type="date"
                       name="EndDate"
                       class="form-control"
                       value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-md-4">
                <div class="filter-actions">
                    <button type="submit" class="btn-filter w-100">
                        <i class="fa-solid fa-filter me-1"></i>
                        Lọc dữ liệu
                    </button>

                    <a asp-page="/Admin/Index" class="btn-clear w-100">
                        Xóa bộ lọc
                    </a>
                </div>
            </div>
        </form>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="metric-card metric-booking">
                <div class="metric-label">
                    Đơn đã đặt
                </div>
                <div class="metric-value">
                    @Model.TotalOrdersCount
                </div>
                <i class="fa-solid fa-receipt metric-icon"></i>
            </div>
        </div>

        <div class="col-md-4">
            <div class="metric-card metric-table">
                <div class="metric-label">
                    Số bàn trống hiện tại
                </div>
                <div class="metric-value">
                    @Model.AvailableTablesCount
                </div>
                <i class="fa-solid fa-table-cells metric-icon"></i>
            </div>
        </div>

        <div class="col-md-4">
            <div class="metric-card metric-revenue">
                <div class="metric-label">
                    Thu nhập
                </div>
                <div class="metric-value revenue">
                    @Model.MonthlyRevenue.ToString("N0") VNĐ
                </div>
                <i class="fa-solid fa-coins metric-icon"></i>
            </div>
        </div>
    </div>

    <div class="booking-card">
        <div class="booking-card-header">
            <span>
                <i class="fa-solid fa-list-check me-2"></i>
                Đơn đã đặt trong khoảng thời gian lọc
            </span>

            <span class="booking-count-badge">
                @(Model.FilteredOrders?.Items.Count ?? 0) đơn
            </span>
        </div>

        <div class="table-responsive">
            <table class="table booking-table">
                <thead>
                    <tr>
                        <th class="ps-3">Mã đơn</th>
                        <th>Ngày tạo</th>
                        <th>Loại đơn</th>
                        <th>Khách hàng</th>
                        <th>Bàn</th>
                        <th>Nhân viên nhận</th>
                        <th class="text-end">Tổng tiền</th>
                        <th class="pe-3">Trạng thái</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.FilteredOrders == null || !Model.FilteredOrders.Items.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center empty-row">
                                Không có order nào trong thời gian này.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var order in Model.FilteredOrders.Items)
                        {
                            var customerName =
                                order.Customer?.FullName ??
                                order.Booking?.GuestName ??
                                "Khách lẻ";
                            var tableName = order.Table?.TableNum ?? order.TableId?.ToString() ?? "-";
                            var staffName =
                                order.ReceivedStaff?.FullName ??
                                order.ReceivedStaffName ??
                                order.InvoiceStaff?.FullName ??
                                order.InvoiceStaffName ??
                                "Chưa xác định";
                            var orderTotal = order.TotalAmount > 0
                                ? order.TotalAmount
                                : order.SubtotalAmount > 0
                                    ? order.SubtotalAmount - order.DiscountAmount
                                    : order.OrderItems.Sum(item => item.TotalPrice);
                            var orderStatusClass = order.OrderStatus switch
                            {
                                BusinessObjects.Enums.OrderStatusEnum.PENDING => "status-pending",
                                BusinessObjects.Enums.OrderStatusEnum.PREPARING => "status-preparing",
                                BusinessObjects.Enums.OrderStatusEnum.COMPLETED => "status-completed",
                                BusinessObjects.Enums.OrderStatusEnum.CANCELLED => "status-cancelled",
                                _ => "status-other"
                            };

                            <tr>
                                <td class="ps-3 booking-id">
                                    #@order.OrderId
                                </td>

                                <td>
                                    @(order.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                                </td>

                                <td>
                                    @if (order.BookingId.HasValue)
                                    {
                                        <span class="source-pill source-booking">
                                            Đặt bàn #@order.BookingId
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="source-pill source-direct">
                                            Không đặt bàn
                                        </span>
                                    }
                                </td>

                                <td class="guest-name">
                                    @customerName
                                </td>

                                <td>
                                    <span class="time-pill">@tableName</span>
                                </td>

                                <td>
                                    @staffName
                                </td>

                                <td class="text-end revenue-cell">
                                    @orderTotal.ToString("N0") đ
                                </td>

                                <td class="pe-3">
                                    <span class="booking-status app-status @orderStatusClass">
                                        @order.OrderStatus
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.FilteredOrders != null && Model.FilteredOrders.Items.Any())
    {
        <partial name="_Pagination" />
    }

</div>
