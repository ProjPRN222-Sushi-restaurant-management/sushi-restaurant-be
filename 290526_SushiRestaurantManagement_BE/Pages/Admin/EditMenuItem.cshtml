@page "{id:long}"
@model _290526_SushiRestaurantManagement_BE.Pages.Admin.EditMenuItemModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chỉnh Sửa Món Ăn";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i>Chỉnh Sửa Món Ăn #@Model.MenuItem.MenuItemId</h5>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <input type="hidden" asp-for="MenuItem.MenuItemId" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Tên món ăn</label>
                    <input asp-for="MenuItem.ItemName" class="form-control" required />
                    <span asp-validation-for="MenuItem.ItemName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Danh mục nhóm món</label>
                    <select asp-for="MenuItem.CategoryId" class="form-select"
                            asp-items="@(new SelectList(Model.Categories, "CategoryId", "CategoryName"))" required>
                    </select>
                    <span asp-validation-for="MenuItem.CategoryId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Đơn giá (VNĐ)</label>
                    <input asp-for="MenuItem.Price" type="number" step="any" class="form-control" min="0" required />
                    <span asp-validation-for="MenuItem.Price" class="text-danger small"></span>
                </div>

                <div class="mb-3 form-check form-switch mt-4">
                    <input class="form-check-input"
                           type="checkbox"
                           id="IsAvailableSwitch"
                           name="IsAvailableInput"
                           value="true"
                           @(Model.MenuItem.IsAvailable == true ? "checked" : "") />

                    <label class="form-check-label fw-semibold" for="IsAvailableSwitch">
                        Còn món ăn
                    </label>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-primary fw-semibold">Lưu thay đổi</button>
                    <a asp-page="/Admin/MenuManager" class="btn btn-outline-secondary">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}