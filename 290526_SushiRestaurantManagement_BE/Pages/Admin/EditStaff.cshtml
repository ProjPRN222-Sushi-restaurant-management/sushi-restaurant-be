@page "{id:int}"
@model _290526_SushiRestaurantManagement_BE.Pages.Admin.EditStaffModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chỉnh Sửa Nhân Viên";
}

<form method="post">

    <input type="hidden" asp-for="StaffInfo.StaffId" />

    <input type="hidden" asp-for="StaffInfo.PasswordHash" />

    <input type="hidden" asp-for="StaffInfo.CreatedAt" />

    <div class="mb-3">

        <label asp-for="StaffInfo.FullName"
               class="form-label fw-semibold">
        </label>

        <input asp-for="StaffInfo.FullName"
               class="form-control"
               required />

    </div>

    <div class="mb-3">

        <label asp-for="StaffInfo.Phone"
               class="form-label fw-semibold">
        </label>

        <input asp-for="StaffInfo.Phone"
               class="form-control"
               required />

    </div>

    <div class="mb-3">

        <label class="form-label fw-semibold text-danger">

            Đổi mật khẩu mới (Để trống nếu giữ nguyên)

        </label>

        <input type="password"
               name="NewPassword"
               class="form-control"
               placeholder="Nhập mật khẩu mới..." />

    </div>

    <div class="mb-3 form-check form-switch mt-4">

        <input class="form-check-input"
               type="checkbox"
               id="IsActiveSwitch"
               name="StaffInfo.IsActive"
               value="true"
               @(Model.StaffInfo.IsActive == true ? "checked" : "") />

        <input type="hidden"
               name="StaffInfo.IsActive"
               value="false" />

        <label class="form-check-label fw-semibold"
               for="IsActiveSwitch">

            Kích hoạt tài khoản làm việc

        </label>

    </div>

    <div class="d-grid gap-2 mt-4">

        <button type="submit"
                class="btn btn-primary fw-semibold">

            Lưu thay đổi

        </button>

        <a asp-page="/Admin/StaffManager"
           class="btn btn-outline-secondary">

            Quay lại

        </a>

    </div>

</form>