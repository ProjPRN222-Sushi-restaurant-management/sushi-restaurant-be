@page
@model _290526_SushiRestaurantManagement_BE.Pages.Order.HistoryModel
@using BusinessObjects.Enums

@section Styles {
    <link rel="stylesheet" href="~/css/pages/order-history.css" asp-append-version="true" />
}

@{
    var allOrders = Model.Orders.OrderBy(o => o.CreatedAt ?? DateTime.MinValue).ToList();
    var overviewOrder = allOrders.LastOrDefault();
    var isTakeaway = Model.Booking == null && overviewOrder != null;
    var orderItemsCount = allOrders.SelectMany(o => o.OrderItems).Sum(i => i.Quantity);
    var discountTotal = allOrders.Sum(o => o.DiscountAmount);
    var earnedPoints = allOrders.Sum(o => o.EarnedLoyaltyPoints);
    var staffId = overviewOrder?.ReceivedStaffId ?? overviewOrder?.InvoiceStaffId;
    var staffName =
        overviewOrder?.ReceivedStaff?.FullName ??
        overviewOrder?.ReceivedStaffName ??
        overviewOrder?.InvoiceStaff?.FullName ??
        overviewOrder?.InvoiceStaffName ??
        "Chưa xác định";
    var receivedAt = overviewOrder?.ReceivedAt ?? overviewOrder?.CreatedAt;
    var customerName =
        Model.Booking?.GuestName ??
        overviewOrder?.Customer?.FullName ??
        "Khách lẻ";
    var customerPhone =
        Model.Booking?.GuestPhone ??
        overviewOrder?.Customer?.Phone ??
        "";
    var tableText = Model.Booking != null
        ? $"Bàn {Model.Booking.TableId}"
        : overviewOrder?.TableId?.ToString() ?? "";
    var statusClass = overviewOrder == null
        ? "status-other"
        : overviewOrder.OrderStatus switch
        {
            OrderStatusEnum.PENDING => "status-pending",
            OrderStatusEnum.PREPARING => "status-preparing",
            OrderStatusEnum.COMPLETED => "status-completed",
            OrderStatusEnum.CANCELLED => "status-cancelled",
            _ => "status-other"
        };
}

<div class="order-history-page @(Model.BillPrint ? "bill-print-mode" : "")">
    <h2 class="page-title">Lịch sử order</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (Model.Booking != null || overviewOrder != null)
    {
        <section class="history-overview-card mb-4">
            <div class="history-overview-header">
                <div>
                    <h5>
                        @(Model.Booking != null
                            ? $"Đặt bàn #{Model.Booking.BookingId}"
                            : $"Đơn mua mang đi #{overviewOrder?.OrderId}")
                    </h5>
                    <span>@allOrders.Count đơn | @orderItemsCount món</span>
                </div>

                @if (overviewOrder != null)
                {
                    <span class="status-pill @statusClass">@overviewOrder.OrderStatus</span>
                }
            </div>

            <div class="history-info-columns">
                <div class="history-info-column">
                    <div class="history-info-row">
                        <span>Khách hàng</span>
                        <strong>@customerName</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Số điện thoại</span>
                        <strong>@customerPhone</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Bàn</span>
                        <strong class="history-important">@tableText</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Ngày booking</span>
                        <strong>@(Model.Booking?.BookingDate.ToString("dd/MM/yyyy") ?? "")</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Giờ booking</span>
                        <strong>@(Model.Booking?.BookingTime.ToString("HH:mm") ?? "")</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Ghi chú</span>
                        <strong>@(Model.Booking?.Note ?? "")</strong>
                    </div>
                </div>

                <div class="history-info-column">
                    <div class="history-info-row">
                        <span>Đơn gần nhất</span>
                        <strong class="history-important">@(overviewOrder != null ? $"#{overviewOrder.OrderId}" : "")</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Nhân viên nhận</span>
                        @if (staffId.HasValue)
                        {
                            <a asp-page="/Admin/EditStaff"
                               asp-route-id="@staffId.Value"
                               class="staff-link">
                                @staffName
                            </a>
                        }
                        else
                        {
                            <strong>@staffName</strong>
                        }
                    </div>

                    <div class="history-info-row">
                        <span>Thời gian nhận</span>
                        <strong>@(receivedAt?.ToString("dd/MM/yyyy HH:mm") ?? "")</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Hạng áp dụng</span>
                        <strong>@(overviewOrder?.MembershipLevelApplied.ToString() ?? "NONE")</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Giảm giá</span>
                        <strong>@(discountTotal > 0 ? $"-{discountTotal:N0} đ" : "")</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Điểm cộng</span>
                        <strong>@earnedPoints điểm</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Thanh toán</span>
                        <strong class="history-money">@(allOrders.Any() ? $"{Model.TemporaryTotal:N0} đ" : "")</strong>
                    </div>
                </div>
            </div>

            @if (allOrders.Count > 1)
            {
                <div class="history-order-line">
                    <span>Các đơn</span>
                    @foreach (var order in allOrders)
                    {
                        var lineStaffName =
                            order.ReceivedStaff?.FullName ??
                            order.ReceivedStaffName ??
                            order.InvoiceStaff?.FullName ??
                            order.InvoiceStaffName ??
                            "Chưa xác định";

                        <span>
                            <strong>Đơn #@order.OrderId</strong>
                            (@order.OrderStatus, @lineStaffName)
                        </span>
                    }
                </div>
            }
        </section>
    }

    @if (!allOrders.Any())
    {
        <div class="empty-order">
            Đơn này chưa có món nào.
        </div>
    }
    else
    {
        <div class="card order-card mb-3">
            <div class="card-header">
                Danh sách món đã order
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table class="table order-table align-middle">
                        <thead>
                            <tr>
                                <th>Món</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in allOrders.SelectMany(o => o.OrderItems))
                            {
                                <tr>
                                    <td>
                                        <strong>@detail.MenuItem.ItemName</strong>
                                    </td>
                                    <td class="text-center">
                                        <span class="qty-badge">@detail.Quantity</span>
                                    </td>
                                    <td class="text-end">
                                        @detail.UnitPrice.ToString("N0") đ
                                    </td>
                                    <td class="text-end money">
                                        @detail.TotalPrice.ToString("N0") đ
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="total-box text-end">
                    <strong>Tổng thanh toán sau giảm:</strong>
                    <span class="money ms-2">@Model.TemporaryTotal.ToString("N0") đ</span>
                </div>
            </div>
        </div>
    }

    @if (allOrders.Any())
    {
        var billSubtotal = allOrders.Sum(o =>
            o.SubtotalAmount > 0
                ? o.SubtotalAmount
                : o.OrderItems.Sum(i => i.TotalPrice));
        var billDiscount = allOrders.Sum(o => o.DiscountAmount);
        var billPaidAt = allOrders
            .OrderByDescending(o => o.CompletedAt ?? o.InvoiceIssuedAt ?? o.CreatedAt)
            .FirstOrDefault()?.CompletedAt ?? DateTime.Now;
        var billStaffName = allOrders
            .Select(o =>
                o.InvoiceStaff?.FullName ??
                o.InvoiceStaffName ??
                o.ReceivedStaff?.FullName ??
                o.ReceivedStaffName)
            .FirstOrDefault(name => !string.IsNullOrWhiteSpace(name)) ?? "Không xác định";

        <section class="payment-bill" aria-label="Hóa đơn thanh toán">
            <h1 class="bill-title">Nhà hàng Sushi</h1>
            <div class="bill-subtitle">Hóa đơn thanh toán</div>

            <div class="bill-meta">
                <div class="bill-line"><span>Đặt bàn</span><strong>@(Model.Booking != null ? $"#{Model.Booking.BookingId}" : "")</strong></div>
                <div class="bill-line"><span>Bàn</span><strong>@(Model.Booking?.TableId.ToString() ?? overviewOrder?.TableId?.ToString() ?? "")</strong></div>
                <div class="bill-line"><span>Khách hàng</span><strong>@customerName</strong></div>
                <div class="bill-line"><span>SĐT</span><strong>@customerPhone</strong></div>
                <div class="bill-line"><span>Nhân viên</span><strong>@billStaffName</strong></div>
                <div class="bill-line"><span>Giờ thanh toán</span><strong>@billPaidAt.ToString("dd/MM/yyyy HH:mm")</strong></div>
            </div>

            <table class="bill-table">
                <thead>
                    <tr>
                        <th>Món</th>
                        <th class="bill-qty">SL</th>
                        <th class="bill-money">Tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detail in allOrders.SelectMany(o => o.OrderItems))
                    {
                        <tr>
                            <td>
                                <div class="bill-dish">@detail.MenuItem.ItemName</div>
                                @if (!string.IsNullOrWhiteSpace(detail.Note))
                                {
                                    <div class="bill-note">@detail.Note</div>
                                }
                            </td>
                            <td class="bill-qty">@detail.Quantity</td>
                            <td class="bill-money">@detail.TotalPrice.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="bill-total">
                <div class="bill-line"><span>Tạm tính</span><strong>@billSubtotal.ToString("N0") đ</strong></div>
                <div class="bill-line"><span>Giảm giá</span><strong>-@billDiscount.ToString("N0") đ</strong></div>
                <div class="bill-line bill-final"><span>Thanh toán</span><strong>@Model.TemporaryTotal.ToString("N0") đ</strong></div>
                <div class="bill-line"><span>Điểm cộng</span><strong>@allOrders.Sum(o => o.EarnedLoyaltyPoints) điểm</strong></div>
            </div>

            <div class="bill-footer">Cảm ơn quý khách và hẹn gặp lại</div>
        </section>
    }

    <div class="action-bar">
        @if (allOrders.Any())
        {
            var isCompleted = allOrders.All(o => o.OrderStatus == OrderStatusEnum.COMPLETED);

            <form method="post"
                  asp-page-handler="PayAndPrintBill"
                  asp-route-bookingId="@Model.Booking?.BookingId"
                  asp-route-orderId="@(isTakeaway ? overviewOrder?.OrderId : null)"
                  class="m-0"
                  onsubmit="return confirm('Xác nhận thanh toán đơn này? Sau khi thanh toán, trạng thái sẽ chuyển sang COMPLETED.');">
                <button type="submit" class="btn btn-pay-bill">
                    <i class="fa-solid fa-receipt me-2"></i>
                    @(isCompleted ? "Xuất hóa đơn" : "Thanh toán + xuất hóa đơn")
                </button>
            </form>
        }

        <a asp-page="/Menu/Index"
           asp-route-bookingId="@Model.Booking?.BookingId"
           asp-route-tableId="@Model.Booking?.TableId"
           class="btn btn-success btn-order-more">
            Gọi thêm món
        </a>

        <a asp-page="/Booking/Reservations"
           class="btn btn-back">
            Quay lại
        </a>
    </div>
</div>

@if (Model.BillPrint)
{
    <script>
        window.addEventListener('load', function () {
            window.print();
        });
    </script>
}
