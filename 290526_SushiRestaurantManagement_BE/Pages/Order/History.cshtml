@page
@model _290526_SushiRestaurantManagement_BE.Pages.Order.HistoryModel
@using BusinessObjects.Enums

@section Styles {
    <link rel="stylesheet" href="~/css/pages/order-history.css" asp-append-version="true" />
}


<div class="order-history-page @(Model.BillPrint ? "bill-print-mode" : "")">

    <h2 class="page-title">Lịch sử order</h2>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (Model.Booking != null)
    {
        var overviewOrders = Model.Orders.OrderBy(o => o.CreatedAt ?? DateTime.MinValue).ToList();
        var overviewOrder = overviewOrders.LastOrDefault();
        var overviewReceivedStaffId = overviewOrder?.ReceivedStaffId ?? overviewOrder?.InvoiceStaffId;
        var overviewReceivedStaffName =
            overviewOrder?.ReceivedStaff?.FullName ??
            overviewOrder?.ReceivedStaffName ??
            overviewOrder?.InvoiceStaff?.FullName ??
            overviewOrder?.InvoiceStaffName ??
            "Chưa xác định";
        var overviewReceivedAt = overviewOrder?.ReceivedAt ?? overviewOrder?.CreatedAt;
        var overviewItemsCount = overviewOrders.SelectMany(o => o.OrderItems).Sum(i => i.Quantity);
        var overviewDiscount = overviewOrders.Sum(o => o.DiscountAmount);
        var overviewPoints = overviewOrders.Sum(o => o.EarnedLoyaltyPoints);
        var overviewLevel = overviewOrder?.MembershipLevelApplied.ToString() ?? "NONE";
        var overviewStatusClass = overviewOrder == null
            ? "status-other"
            : overviewOrder.OrderStatus switch
            {
                OrderStatusEnum.PENDING => "status-pending",
                OrderStatusEnum.PREPARING => "status-preparing",
                OrderStatusEnum.COMPLETED => "status-completed",
                OrderStatusEnum.CANCELLED => "status-cancelled",
                _ => "status-other"
            };

        <section class="history-overview-card mb-4">
            <div class="history-overview-header">
                <div>
                    <h5>Booking #@Model.Booking.BookingId</h5>
                    <span>@overviewOrders.Count order | @overviewItemsCount món</span>
                </div>
                @if (overviewOrder != null)
                {
                    <span class="status-pill @overviewStatusClass">@overviewOrder.OrderStatus</span>
                }
            </div>

            <div class="history-info-columns">
                <div class="history-info-column">
                    <div class="history-info-row">
                        <span>Khách hàng</span>
                        <strong>@Model.Booking.GuestName</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Số điện thoại</span>
                        <strong>@Model.Booking.GuestPhone</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Bàn</span>
                        <strong class="history-important">Bàn @Model.Booking.TableId</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Ngày booking</span>
                        <strong>@Model.Booking.BookingDate</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Giờ booking</span>
                        <strong>@Model.Booking.BookingTime</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Ghi chú</span>
                        <strong>@(string.IsNullOrWhiteSpace(Model.Booking.Note) ? "-" : Model.Booking.Note)</strong>
                    </div>
                </div>

                <div class="history-info-column">
                    <div class="history-info-row">
                        <span>Order gần nhất</span>
                        <strong class="history-important">@(overviewOrder != null ? $"#{overviewOrder.OrderId}" : "-")</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Nhân viên nhận</span>
                    @if (overviewReceivedStaffId.HasValue)
                    {
                        <a asp-page="/Admin/EditStaff"
                           asp-route-id="@overviewReceivedStaffId.Value"
                           class="staff-link">
                            @overviewReceivedStaffName
                        </a>
                    }
                    else
                    {
                        <strong>@overviewReceivedStaffName</strong>
                    }
                    </div>

                    <div class="history-info-row">
                        <span>Thời gian nhận</span>
                        <strong>@(overviewReceivedAt?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa nhận")</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Hạng áp dụng</span>
                        <strong>@overviewLevel</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Giảm giá</span>
                        <strong>@(overviewDiscount > 0 ? $"-{overviewDiscount:N0} đ" : "-")</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Điểm cộng</span>
                        <strong>@overviewPoints điểm</strong>
                    </div>

                    <div class="history-info-row">
                        <span>Thanh toán</span>
                        <strong class="history-money">@(overviewOrders.Any() ? $"{Model.TemporaryTotal:N0} đ" : "-")</strong>
                    </div>
                </div>
            </div>

            @if (overviewOrders.Count > 1)
            {
                <div class="history-order-line">
                    <span>Các order</span>
                    @foreach (var order in overviewOrders)
                    {
                        var stripStaffName =
                            order.ReceivedStaff?.FullName ??
                            order.ReceivedStaffName ??
                            order.InvoiceStaff?.FullName ??
                            order.InvoiceStaffName ??
                            "Chưa xác định";

                        <span>
                            <strong>Order #@order.OrderId</strong>
                            (@order.OrderStatus, @stripStaffName)
                        </span>
                    }
                </div>
            }
        </section>
    }

    @if (!Model.Orders.Any())
    {
        <div class="empty-order">
            Booking này chưa có món nào được order.
        </div>
    }
    else
    {
        <div class="card order-card mb-3">
            <div class="card-header">
                Danh sách món đã order
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table class="table order-table align-middle">
                        <thead>
                            <tr>
                                <th>Món</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in Model.Orders.SelectMany(o => o.OrderItems))
                            {
                                <tr>
                                    <td>
                                        <strong>@detail.MenuItem.ItemName</strong>
                                    </td>
                                    <td class="text-center">
                                        <span class="qty-badge">@detail.Quantity</span>
                                    </td>
                                    <td class="text-end">
                                        @detail.UnitPrice.ToString("N0") đ
                                    </td>
                                    <td class="text-end money">
                                        @((detail.Quantity * detail.UnitPrice).ToString("N0")) đ
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="total-box text-end">
                    <strong>Tổng thanh toán sau giảm:</strong>
                    <span class="money ms-2">@Model.TemporaryTotal.ToString("N0") đ</span>
                </div>
            </div>
        </div>
    }
    @if (Model.Orders.Any() && Model.Booking != null)
    {
        var billOrders = Model.Orders.ToList();
        var billSubtotal = billOrders.Sum(o =>
            o.SubtotalAmount > 0
                ? o.SubtotalAmount
                : o.OrderItems.Sum(i => i.TotalPrice));
        var billDiscount = billOrders.Sum(o => o.DiscountAmount);
        var billPaidAt = billOrders
            .OrderByDescending(o => o.CompletedAt ?? o.InvoiceIssuedAt ?? o.CreatedAt)
            .FirstOrDefault()?.CompletedAt ?? DateTime.Now;
        var billStaffName = billOrders
            .Select(o =>
                o.InvoiceStaff?.FullName ??
                o.InvoiceStaffName ??
                o.ReceivedStaff?.FullName ??
                o.ReceivedStaffName)
            .FirstOrDefault(name => !string.IsNullOrWhiteSpace(name)) ?? "Không xác định";

        <section class="payment-bill" aria-label="Bill thanh toán">
            <h1 class="bill-title">Sushi Restaurant</h1>
            <div class="bill-subtitle">Hóa đơn thanh toán</div>

            <div class="bill-meta">
                <div class="bill-line"><span>Booking</span><strong>#@Model.Booking.BookingId</strong></div>
                <div class="bill-line"><span>Bàn</span><strong>@Model.Booking.TableId</strong></div>
                <div class="bill-line"><span>Khách hàng</span><strong>@Model.Booking.GuestName</strong></div>
                <div class="bill-line"><span>SĐT</span><strong>@Model.Booking.GuestPhone</strong></div>
                <div class="bill-line"><span>Nhân viên</span><strong>@billStaffName</strong></div>
                <div class="bill-line"><span>Giờ thanh toán</span><strong>@billPaidAt.ToString("dd/MM/yyyy HH:mm")</strong></div>
            </div>

            <table class="bill-table">
                <thead>
                    <tr>
                        <th>Món</th>
                        <th class="bill-qty">SL</th>
                        <th class="bill-money">Tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detail in billOrders.SelectMany(o => o.OrderItems))
                    {
                        <tr>
                            <td>
                                <div class="bill-dish">@detail.MenuItem.ItemName</div>
                                @if (!string.IsNullOrWhiteSpace(detail.Note))
                                {
                                    <div class="bill-note">@detail.Note</div>
                                }
                            </td>
                            <td class="bill-qty">@detail.Quantity</td>
                            <td class="bill-money">@detail.TotalPrice.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="bill-total">
                <div class="bill-line"><span>Tạm tính</span><strong>@billSubtotal.ToString("N0") đ</strong></div>
                <div class="bill-line"><span>Giảm giá</span><strong>-@billDiscount.ToString("N0") đ</strong></div>
                <div class="bill-line bill-final"><span>Thanh toán</span><strong>@Model.TemporaryTotal.ToString("N0") đ</strong></div>
                <div class="bill-line"><span>Điểm cộng</span><strong>@billOrders.Sum(o => o.EarnedLoyaltyPoints) điểm</strong></div>
            </div>

            <div class="bill-footer">Cảm ơn quý khách và hẹn gặp lại</div>
        </section>
    }

    <div class="action-bar">
        @if (Model.Orders.Any() && Model.Booking != null)
        {
            var isCompleted = Model.Orders.All(o => o.OrderStatus == OrderStatusEnum.COMPLETED);

            <form method="post"
                  asp-page-handler="PayAndPrintBill"
                  asp-route-bookingId="@Model.Booking.BookingId"
                  class="m-0"
                  onsubmit="return confirm('Xác nhận thanh toán booking này? Sau khi thanh toán, booking sẽ COMPLETED và bàn trở về AVAILABLE.');">
                <button type="submit" class="btn btn-pay-bill">
                    <i class="fa-solid fa-receipt me-2"></i>
                    @(isCompleted ? "Xuất hóa đơn" : "Thanh toán + xuất bill")
                </button>
            </form>
        }
        <a asp-page="/Menu/Index"
           asp-route-bookingId="@Model.Booking?.BookingId"
           asp-route-tableId="@Model.Booking?.TableId"
           class="btn btn-success btn-order-more">
            Order thêm
        </a>

        <a asp-page="/Booking/Reservations"
           class="btn btn-back">
            Quay lại
        </a>
    </div>

</div>

@if (Model.BillPrint)
{
    <script>
        window.addEventListener('load', function () {
            window.print();
        });
    </script>
}
