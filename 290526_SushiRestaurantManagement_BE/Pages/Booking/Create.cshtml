@page
@model _290526_SushiRestaurantManagement_BE.Pages.Booking.CreateModel
@using BusinessObjects.Enums

<h2>Đặt bàn Sushi</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        Vui lòng kiểm tra lại thông tin đặt bàn.
    </div>
}

<form method="post" class="booking-form">
    <div>
        <label>Ngày đặt</label>
        <input asp-for="Input.BookingDate" type="date" class="form-control" />
    </div>

    <div>
        <label>Giờ đặt</label>
        <input asp-for="Input.BookingTime" type="time" class="form-control" />
    </div>

    <div>
        <label>Số người lớn</label>
        <input asp-for="Input.AdultCount" type="number" min="1" class="form-control" />
    </div>

    <div>
        <label>Số trẻ em</label>
        <input asp-for="Input.ChildCount" type="number" min="0" class="form-control" />
    </div>

    <div>
        <label>Khu vực mong muốn</label>
        <select asp-for="Input.TableType" class="form-control">
            <option value="@TableTypeEnum.NORMAL">Bàn thường</option>
            <option value="@TableTypeEnum.BAR">Quầy bar xem đầu bếp làm sushi</option>
            <option value="@TableTypeEnum.VIP">VIP</option>
        </select>
    </div>

    <div>
        <label>Họ tên</label>
        <input asp-for="Input.GuestName" class="form-control" />
    </div>

    <div>
        <label>Số điện thoại</label>
        <input asp-for="Input.GuestPhone" class="form-control" />
    </div>

    <div>
        <label>Ghi chú</label>
        <textarea asp-for="Input.Note" class="form-control"
                  placeholder="Tiệc sinh nhật, cần ghế trẻ em, dị ứng..."></textarea>
    </div>

    <p class="mt-3">
        Bàn phù hợp hiện có: <strong>@Model.AvailableTableCount</strong>
    </p>

    @if (Model.AvailableTables.Any())
    {
        <div class="alert alert-success">
            <strong>Các bàn còn trống:</strong>
            <ul>
                @foreach (var table in Model.AvailableTables)
                {
                    <li>
                        Bàn @table.TableNum - Sức chứa: @table.Capacity - Loại: @table.TableType
                    </li>
                }
            </ul>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            Khung giờ này đã hết bàn phù hợp.
        </div>
    }

    @if (Model.ExistingBookings.Any())
    {
        <div class="alert alert-warning">
            <strong>Khung giờ này đã có người đặt:</strong>
            <ul>
                @foreach (var booking in Model.ExistingBookings)
                {
                    <li>
                        Bàn ID: @booking.TableId -
                        Khách: @booking.GuestName -
                        SĐT: @booking.GuestPhone
                    </li>
                }
            </ul>
        </div>
    }

    <button type="submit" class="btn btn-primary">Xác nhận đặt bàn</button>
</form>
